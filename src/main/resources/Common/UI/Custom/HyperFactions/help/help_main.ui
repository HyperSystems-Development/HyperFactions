// Help Center - Wide sidebar layout (750x650)
// Left: Colored category sidebar (180px), Right: Scrollable card content
$C = "../../Common.ui";
$S = "../shared/styles.ui";
$Nav = "../nav/nav_bar.ui";

// === Sidebar button styles per category ===
// Each category has a unique Disabled label color matching its accent

@SidebarLabel = LabelStyle(
  FontSize: 11,
  TextColor: #bfcdd5,
  RenderBold: true
);

// Welcome (#00FFFF)
@SidebarLabelCyan = LabelStyle(
  FontSize: 11,
  TextColor: #00FFFF,
  RenderBold: true
);
@CatStyleCyan = TextButtonStyle(
  Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: @SidebarLabel),
  Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: @SidebarLabel),
  Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: @SidebarLabel),
  Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: @SidebarLabelCyan),
  Sounds: $C.@ButtonSounds
);

// Your Faction (#44CC44)
@SidebarLabelGreen = LabelStyle(
  FontSize: 11,
  TextColor: #44CC44,
  RenderBold: true
);
@CatStyleGreen = TextButtonStyle(
  Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: @SidebarLabel),
  Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: @SidebarLabel),
  Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: @SidebarLabel),
  Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: @SidebarLabelGreen),
  Sounds: $C.@ButtonSounds
);

// Power & Land (#FFD700)
@SidebarLabelGold = LabelStyle(
  FontSize: 11,
  TextColor: #FFD700,
  RenderBold: true
);
@CatStyleGold = TextButtonStyle(
  Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: @SidebarLabel),
  Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: @SidebarLabel),
  Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: @SidebarLabel),
  Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: @SidebarLabelGold),
  Sounds: $C.@ButtonSounds
);

// Diplomacy (#55AAFF)
@SidebarLabelBlue = LabelStyle(
  FontSize: 11,
  TextColor: #55AAFF,
  RenderBold: true
);
@CatStyleBlue = TextButtonStyle(
  Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: @SidebarLabel),
  Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: @SidebarLabel),
  Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: @SidebarLabel),
  Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: @SidebarLabelBlue),
  Sounds: $C.@ButtonSounds
);

// Combat & Safety (#FF5555)
@SidebarLabelRed = LabelStyle(
  FontSize: 11,
  TextColor: #FF5555,
  RenderBold: true
);
@CatStyleRed = TextButtonStyle(
  Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: @SidebarLabel),
  Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: @SidebarLabel),
  Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: @SidebarLabel),
  Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: @SidebarLabelRed),
  Sounds: $C.@ButtonSounds
);

// Economy (#FFAA00)
@SidebarLabelOrange = LabelStyle(
  FontSize: 11,
  TextColor: #FFAA00,
  RenderBold: true
);
@CatStyleOrange = TextButtonStyle(
  Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: @SidebarLabel),
  Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: @SidebarLabel),
  Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: @SidebarLabel),
  Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: @SidebarLabelOrange),
  Sounds: $C.@ButtonSounds
);

// Quick Reference (#888888)
@SidebarLabelGray = LabelStyle(
  FontSize: 11,
  TextColor: #888888,
  RenderBold: true
);
@CatStyleGray = TextButtonStyle(
  Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: @SidebarLabel),
  Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: @SidebarLabel),
  Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: @SidebarLabel),
  Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: @SidebarLabelGray),
  Sounds: $C.@ButtonSounds
);

$C.@PageOverlay {
  $Nav.@HyperFactionsNavBar #HyperFactionsNavBar {}

  $C.@DecoratedContainer {
    Anchor: (Width: 750, Height: 650);

    #Title {
      Group {
        $C.@Title #PageTitle {
          @Text = "Help Center";
        }
      }
    }

    #Content {
      LayoutMode: Left;
      Padding: (Left: 10, Right: 10, Top: 10, Bottom: 10);

      // Left column - Colored category sidebar (180px)
      Group #CategoryMenu {
        Anchor: (Width: 180);
        LayoutMode: Top;
        Padding: (Left: 0, Right: 8, Top: 0, Bottom: 0);

        // Category 0: Welcome (cyan)
        Group {
          Anchor: (Height: 34, Bottom: 2);
          LayoutMode: Left;

          Group #Bar0 {
            Anchor: (Width: 3);
            Background: (Color: #00FFFF);
          }

          TextButton #Cat0 {
            Text: "  Welcome";
            FlexWeight: 1;
            Anchor: (Height: 34);
            Style: @CatStyleCyan;
          }
        }

        // Category 1: Your Faction (green)
        Group {
          Anchor: (Height: 34, Bottom: 2);
          LayoutMode: Left;

          Group #Bar1 {
            Anchor: (Width: 3);
            Background: (Color: #44CC44);
          }

          TextButton #Cat1 {
            Text: "  Your Faction";
            FlexWeight: 1;
            Anchor: (Height: 34);
            Style: @CatStyleGreen;
          }
        }

        // Category 2: Power & Land (gold)
        Group {
          Anchor: (Height: 34, Bottom: 2);
          LayoutMode: Left;

          Group #Bar2 {
            Anchor: (Width: 3);
            Background: (Color: #FFD700);
          }

          TextButton #Cat2 {
            Text: "  Power & Land";
            FlexWeight: 1;
            Anchor: (Height: 34);
            Style: @CatStyleGold;
          }
        }

        // Category 3: Diplomacy (blue)
        Group {
          Anchor: (Height: 34, Bottom: 2);
          LayoutMode: Left;

          Group #Bar3 {
            Anchor: (Width: 3);
            Background: (Color: #55AAFF);
          }

          TextButton #Cat3 {
            Text: "  Diplomacy";
            FlexWeight: 1;
            Anchor: (Height: 34);
            Style: @CatStyleBlue;
          }
        }

        // Category 4: Combat & Safety (red)
        Group {
          Anchor: (Height: 34, Bottom: 2);
          LayoutMode: Left;

          Group #Bar4 {
            Anchor: (Width: 3);
            Background: (Color: #FF5555);
          }

          TextButton #Cat4 {
            Text: "  Combat & Safety";
            FlexWeight: 1;
            Anchor: (Height: 34);
            Style: @CatStyleRed;
          }
        }

        // Category 5: Economy (orange)
        Group {
          Anchor: (Height: 34, Bottom: 2);
          LayoutMode: Left;

          Group #Bar5 {
            Anchor: (Width: 3);
            Background: (Color: #FFAA00);
          }

          TextButton #Cat5 {
            Text: "  Economy";
            FlexWeight: 1;
            Anchor: (Height: 34);
            Style: @CatStyleOrange;
          }
        }

        // Category 6: Quick Reference (gray)
        Group {
          Anchor: (Height: 34, Bottom: 2);
          LayoutMode: Left;

          Group #Bar6 {
            Anchor: (Width: 3);
            Background: (Color: #888888);
          }

          TextButton #Cat6 {
            Text: "  Quick Reference";
            FlexWeight: 1;
            Anchor: (Height: 34);
            Style: @CatStyleGray;
          }
        }
      }

      // Divider line
      Group {
        Anchor: (Width: 1);
        Background: (Color: #2a3a4a);
      }

      // Right column - Scrollable content area
      Group #ContentArea {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Padding: (Left: 15, Right: 10, Top: 0, Bottom: 10);

        // Category title header (set from Java)
        Label #CategoryTitle {
          Text: "";
          Style: (FontSize: 14, TextColor: #00FFFF, RenderBold: true);
          Anchor: (Height: 28, Left: 0, Right: 0);
        }

        // Spacer after title
        Group {
          Anchor: (Height: 6);
        }

        // Dynamic content container for topic cards
        Group #ContentList {
          LayoutMode: Top;
        }
      }
    }
  }
}

$C.@BackButton {}
