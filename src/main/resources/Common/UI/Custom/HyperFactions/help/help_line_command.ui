// Help content line - command callout (yellow bold, slight indent, wrapping)

Group {
  Padding: (Left: 8, Top: 1, Bottom: 1);

  Label #Text {
    Text: "";
    Style: (FontSize: 11, TextColor: #FFFF55, RenderBold: true, Wrap: true, VerticalAlignment: Center);
    Anchor: (Left: 0, Right: 0);
  }
}
