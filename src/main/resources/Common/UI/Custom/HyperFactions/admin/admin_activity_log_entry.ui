// Admin Activity Log Entry
// Appended into #LogList per log entry

Group {
  Anchor: (Height: 36, Bottom: 2);
  Background: (Color: #0d1520);
  Padding: (Left: 12, Right: 12, Top: 6, Bottom: 6);
  LayoutMode: Left;

  Label #LogTime {
    Text: "just now";
    Style: (FontSize: 10, TextColor: #666666, VerticalAlignment: Center);
    Anchor: (Width: 80);
  }

  Label #LogType {
    Text: "Type";
    Style: (FontSize: 10, TextColor: #00AAAA, RenderBold: true, VerticalAlignment: Center);
    Anchor: (Width: 65);
  }

  Label #FactionName {
    Text: "Faction";
    Style: (FontSize: 11, TextColor: #FFFFFF, VerticalAlignment: Center);
    Anchor: (Width: 120);
  }

  Label #LogMessage {
    Text: "Activity description";
    Style: (FontSize: 11, TextColor: #AAAAAA, VerticalAlignment: Center);
    FlexWeight: 1;
  }
}
