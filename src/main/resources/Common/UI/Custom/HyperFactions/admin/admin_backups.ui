$C = "../../Common.ui";
$S = "../shared/styles.ui";
$Nav = "admin_nav_bar.ui";

$C.@PageOverlay {
  $Nav.@HyperFactionsAdminNavBar #HyperFactionsAdminNavBar {}

  $C.@Container {
    Anchor: (Width: 600, Height: 470);

    #Title {
      $C.@Title #PageTitle {
        @Text = "Backups";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 15, Right: 15, Top: 10, Bottom: 10);

      Group #HeaderRow {
        LayoutMode: Left;
        Anchor: (Height: 32, Bottom: 6);

        Label #BackupCount {
          Text: "";
          Style: (FontSize: 13, TextColor: #CCCCCC, RenderBold: true);
          Anchor: (Width: 260, Height: 28);
        }

        Group { Anchor: (Width: 10); FlexWeight: 1; }

        TextButton #CreateBackupBtn {
          Style: $S.@CyanButtonStyle;
          Text: "Create Backup";
          Anchor: (Width: 140, Height: 28);
        }
      }

      Group #NameInputRow {
        LayoutMode: Left;
        Anchor: (Height: 28, Bottom: 6);

        Label #NameLabel {
          Text: "Name:";
          Style: (FontSize: 11, TextColor: #888888, VerticalAlignment: Center);
          Anchor: (Width: 50, Height: 28);
        }

        $C.@TextField #BackupNameInput {
          Anchor: (Width: 200, Height: 28);
        }

        Group { FlexWeight: 1; }

        Label #FilterLabel {
          Text: "Filter:";
          Style: (FontSize: 11, TextColor: #888888, VerticalAlignment: Center);
          Anchor: (Width: 40, Height: 28);
        }

        DropdownBox #FilterDropdown {
          Style: $C.@DefaultDropdownBoxStyle;
          Anchor: (Width: 120, Height: 26);
        }
      }

      Label #StatusMessage {
        Text: "";
        Style: (FontSize: 10, TextColor: #888888);
        Anchor: (Height: 18, Bottom: 4);
      }

      Group #SeparatorLine {
        Background: (Color: #333333);
        Anchor: (Height: 1, Bottom: 6);
      }

      Group #BackupListContainer {
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        FlexWeight: 1;
      }

      Group #PaginationRow {
        LayoutMode: Left;
        Anchor: (Height: 28, Top: 6);

        TextButton #PrevBtn {
          Style: $S.@ButtonStyle;
          Text: "< Prev";
          Anchor: (Width: 80, Height: 24);
          Visible: false;
        }

        Group { FlexWeight: 1; }

        Label #PageLabel {
          Text: "";
          Style: (FontSize: 11, TextColor: #888888, HorizontalAlignment: Center);
          Anchor: (Width: 120, Height: 24);
        }

        Group { FlexWeight: 1; }

        TextButton #NextBtn {
          Style: $S.@ButtonStyle;
          Text: "Next >";
          Anchor: (Width: 80, Height: 24);
          Visible: false;
        }
      }
    }
  }
}

$C.@BackButton {}
