$C = "../../Common.ui";
$S = "../shared/styles.ui";

Group {
  LayoutMode: Left;
  Anchor: (Height: 22, Bottom: 3);
  Padding: (Left: 6, Right: 4);

  Label #SettingLabel {
    Text: "";
    Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
    FlexWeight: 1;
  }

  $C.@TextField #StrInput {
    Anchor: (Width: 200, Height: 20);
  }
}
