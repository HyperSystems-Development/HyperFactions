$C = "../../Common.ui";
$S = "../shared/styles.ui";

Group {
  LayoutMode: Left;
  Anchor: (Height: 26, Top: 4);
  Padding: (Left: 6, Right: 4);

  $C.@TextField #AddInput {
    Anchor: (Width: 160, Height: 22);
  }

  Group { Anchor: (Width: 6); }

  TextButton #AddBtn {
    Style: $S.@ButtonStyle;
    Text: "Add";
    Anchor: (Width: 80, Height: 22);
  }
}
