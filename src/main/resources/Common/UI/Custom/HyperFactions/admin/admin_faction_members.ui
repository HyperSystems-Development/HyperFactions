// Admin Faction Members Page
// Full admin member list with search, sort dropdown, pagination
// Matches AdminFactionsPage gold standard (700x500, Container)

$C = "../../Common.ui";
$S = "../shared/styles.ui";
$Nav = "admin_nav_bar.ui";

$C.@PageOverlay {
  $Nav.@HyperFactionsAdminNavBar #HyperFactionsAdminNavBar {}

  $C.@Container {
    Anchor: (Width: 700, Height: 500);

    #Title {
      Group {
        LayoutMode: Left;

        Group {
          $C.@Title {
            @Text = "Admin: Members";
          }
        }

        Label { FlexWeight: 1; }

        Label #FactionName {
          Text: "";
          Style: (FontSize: 14, TextColor: #00FFFF, RenderBold: true, VerticalAlignment: Center);
          Anchor: (Right: 10);
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 15, Right: 15, Top: 10, Bottom: 10);

      // Search row
      Group {
        Anchor: (Height: 38, Bottom: 8);
        LayoutMode: Left;

        Label {
          Text: "Search:";
          Style: (FontSize: 11, TextColor: #888888, VerticalAlignment: Center);
          Anchor: (Width: 55);
        }

        $C.@TextField #SearchInput {
          FlexWeight: 1;
          Anchor: (Height: 32);
        }
      }

      // Header row with member count, sort, and back button
      Group {
        Anchor: (Height: 35, Bottom: 8);
        LayoutMode: Left;

        Label #MemberCount {
          Text: "0 members";
          Style: (FontSize: 13, TextColor: #888888, VerticalAlignment: Center);
          Anchor: (Width: 120);
        }

        Group { FlexWeight: 1; }

        Label {
          Text: "Sort:";
          Style: (FontSize: 11, TextColor: #888888, VerticalAlignment: Center);
          Anchor: (Width: 35);
        }
        DropdownBox #SortDropdown {
          Style: $C.@DefaultDropdownBoxStyle;
          Anchor: (Height: 28, Width: 150);
        }

        Group { Anchor: (Width: 10); }

        TextButton #BackBtn {
          Text: "Back";
          Anchor: (Height: 26, Width: 60);
          Style: $S.@ButtonStyle;
        }
      }

      // Divider
      Group {
        Anchor: (Height: 1, Bottom: 8);
        Background: (Color: #00AAAA);
      }

      // Scrollable member list
      Group #MembersListContainer {
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        FlexWeight: 1;

        Group #MembersList {
          LayoutMode: Top;
        }
      }

      // Divider
      Group {
        Anchor: (Height: 1, Top: 8, Bottom: 8);
        Background: (Color: #00AAAA);
      }

      // Pagination
      Group #Pagination {
        Anchor: (Height: 35);
        LayoutMode: Left;

        TextButton #PrevBtn {
          Text: "< Prev";
          Anchor: (Height: 26, Width: 80);
          Style: $S.@ButtonStyle;
        }

        Label { FlexWeight: 1; }

        Label #PageInfo {
          Text: "1/1";
          Style: (FontSize: 14, TextColor: #888888, HorizontalAlignment: Center, VerticalAlignment: Center);
          Anchor: (Width: 60);
        }

        Label { FlexWeight: 1; }

        TextButton #NextBtn {
          Text: "Next >";
          Anchor: (Height: 26, Width: 80);
          Style: $S.@ButtonStyle;
        }
      }
    }
  }
}

$C.@BackButton {}
