// Admin Player Info Page
// Card-based stat layout matching admin dashboard style
// Back button returns to AdminFactionMembersPage

$C = "../../Common.ui";
$S = "../shared/styles.ui";
$Nav = "admin_nav_bar.ui";

$C.@PageOverlay {
  $Nav.@HyperFactionsAdminNavBar #HyperFactionsAdminNavBar {}

  $C.@Container {
    Anchor: (Width: 560, Height: 580);

    #Title {
      $C.@Title {
        @Text = "Admin: Player Info";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 20, Right: 20, Top: 15, Bottom: 15);

      // === Header Section ===
      Group #HeaderSection {
        Anchor: (Height: 55, Bottom: 8);
        LayoutMode: Top;

        // Player name, status, faction row
        Group {
          LayoutMode: Left;
          Anchor: (Height: 28);

          Label #PlayerName {
            Text: "PlayerName";
            Style: (FontSize: 18, TextColor: #4a9eff, RenderBold: true, VerticalAlignment: Center);
          }

          Label { Anchor: (Width: 10); }

          Label #OnlineStatus {
            Text: "Online";
            Style: (FontSize: 12, TextColor: #55FF55, RenderBold: true, VerticalAlignment: Center);
          }

          Label { FlexWeight: 1; }

          Label #FactionName {
            Text: "";
            Style: (FontSize: 14, TextColor: #00FFFF, RenderBold: true, VerticalAlignment: Center);
          }
        }

        // Role subtitle
        Group {
          LayoutMode: Left;
          Anchor: (Height: 18);

          Label #RoleLabel {
            Text: "";
            Style: (FontSize: 11, TextColor: #888888, VerticalAlignment: Center);
          }
        }
      }

      // === Stats Row - 3 stat cards ===
      Group #StatsRow {
        Anchor: (Height: 75, Bottom: 10);
        LayoutMode: Left;

        // Power card
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Right: 4);

          Label {
            Text: "Power";
            Style: (FontSize: 9, TextColor: #666666);
            Anchor: (Height: 14);
          }
          Label #PowerValue {
            Text: "0 / 0";
            Style: (FontSize: 20, TextColor: #FFFFFF, RenderBold: true);
            FlexWeight: 1;
          }
          Label #MaxOverrideLabel {
            Text: "";
            Style: (FontSize: 9, TextColor: #888888);
            Anchor: (Height: 14);
          }
        }

        // Combat card
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4, Right: 4);

          Label {
            Text: "Combat";
            Style: (FontSize: 9, TextColor: #666666);
            Anchor: (Height: 14);
          }
          Group {
            FlexWeight: 1;
            LayoutMode: Left;

            Label #KillsValue {
              Text: "0";
              Style: (FontSize: 16, TextColor: #55FF55, RenderBold: true, VerticalAlignment: Center);
              FlexWeight: 1;
            }
            Label {
              Text: "/";
              Style: (FontSize: 14, TextColor: #444444, VerticalAlignment: Center);
              Anchor: (Width: 12);
            }
            Label #DeathsValue {
              Text: "0";
              Style: (FontSize: 16, TextColor: #FF5555, RenderBold: true, VerticalAlignment: Center);
              FlexWeight: 1;
            }
          }
          Label {
            Text: "kills / deaths";
            Style: (FontSize: 9, TextColor: #444444);
            Anchor: (Height: 14);
          }
        }

        // KDR card
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4);

          Label {
            Text: "K/D Ratio";
            Style: (FontSize: 9, TextColor: #666666);
            Anchor: (Height: 14);
          }
          Label #KDRValue {
            Text: "0.00";
            Style: (FontSize: 20, TextColor: #FFFFFF, RenderBold: true);
            FlexWeight: 1;
          }
          Label {
            Text: "";
            Style: (FontSize: 9, TextColor: #444444);
            Anchor: (Height: 14);
          }
        }
      }

      // Cyan divider
      Group {
        Anchor: (Height: 1, Bottom: 8);
        Background: (Color: #00AAAA);
      }

      // === Power Management Section ===
      Group {
        Background: (Color: #1a2a3a);
        Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
        LayoutMode: Top;
        Anchor: (Height: 126, Bottom: 8);

        // Section header row with power bar preview
        Group {
          LayoutMode: Left;
          Anchor: (Height: 20, Bottom: 4);

          Label {
            Text: "Power Management";
            Style: (FontSize: 11, TextColor: #666666, RenderBold: true, VerticalAlignment: Center);
          }

          Label { FlexWeight: 1; }

          Label #MaxPowerValue {
            Text: "20.0";
            Style: (FontSize: 11, TextColor: #888888, VerticalAlignment: Center);
          }
        }

        // Power bar
        ProgressBar #PowerBar {
          Anchor: (Height: 8, Bottom: 8);
          Value: 0.5;
          Bar: (Color: #55FF55);
          Background: (Color: #0d1520);
        }

        // Quick adjust buttons row
        Group {
          LayoutMode: Left;
          Anchor: (Height: 30, Bottom: 6);

          TextButton #SubFive {
            Text: "-5";
            Anchor: (Height: 26, Width: 42, Right: 4);
            Style: $S.@RedButtonStyle;
          }

          TextButton #SubOne {
            Text: "-1";
            Anchor: (Height: 26, Width: 42, Right: 6);
            Style: $S.@RedButtonStyle;
          }

          $C.@TextField #PowerInput {
            Anchor: (Height: 26, Width: 80, Right: 6);
            Style: (FontSize: 12, TextColor: #FFFFFF);
          }

          TextButton #AddOne {
            Text: "+1";
            Anchor: (Height: 26, Width: 42, Right: 4);
            Style: $S.@ButtonStyle;
          }

          TextButton #AddFive {
            Text: "+5";
            Anchor: (Height: 26, Width: 42, Right: 8);
            Style: $S.@ButtonStyle;
          }

          TextButton #SetPowerBtn {
            Text: "Set";
            Anchor: (Height: 26, Width: 50, Right: 4);
            Style: $S.@CyanButtonStyle;
          }

          TextButton #ResetPowerBtn {
            Text: "Reset";
            Anchor: (Height: 26, Width: 55);
            Style: $S.@RedButtonStyle;
          }
        }

        // Max power row
        Group {
          LayoutMode: Left;
          Anchor: (Height: 30);

          Label {
            Text: "Max Power:";
            Style: (FontSize: 12, TextColor: #AAAAAA, VerticalAlignment: Center);
            Anchor: (Width: 80);
          }

          $C.@TextField #MaxPowerInput {
            Anchor: (Height: 26, Width: 80, Right: 6);
            Style: (FontSize: 12, TextColor: #FFFFFF);
          }

          TextButton #SetMaxBtn {
            Text: "Set Max";
            Anchor: (Height: 26, Width: 70, Right: 4);
            Style: $S.@CyanButtonStyle;
          }

          TextButton #ResetMaxBtn {
            Text: "Reset";
            Anchor: (Height: 26, Width: 55);
            Style: $S.@RedButtonStyle;
          }
        }
      }

      // Cyan divider
      Group {
        Anchor: (Height: 1, Bottom: 8);
        Background: (Color: #00AAAA);
      }

      // === Bypass Toggles Section ===
      Group {
        Background: (Color: #1a2a3a);
        Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
        LayoutMode: Top;
        Anchor: (Height: 104, Bottom: 8);

        // Section header
        Group {
          Anchor: (Height: 20, Bottom: 4);

          Label {
            Text: "Power Bypass Toggles";
            Style: (FontSize: 11, TextColor: #666666, RenderBold: true);
          }
        }

        // No Loss toggle row
        Group {
          LayoutMode: Left;
          Anchor: (Height: 28, Bottom: 4);

          $C.@CheckBoxWithLabel #NoLossCheck {
            @Text = "Disable Power Loss";
            @Checked = false;
            Anchor: (Height: 24, Width: 200);
          }

          Label #NoLossStatus {
            Text: "Off";
            Style: (FontSize: 11, TextColor: #888888, VerticalAlignment: Center);
            Anchor: (Left: 8);
          }
        }

        // No Decay toggle row
        Group {
          LayoutMode: Left;
          Anchor: (Height: 28);

          $C.@CheckBoxWithLabel #NoDecayCheck {
            @Text = "Disable Claim Decay";
            @Checked = false;
            Anchor: (Height: 24, Width: 200);
          }

          Label #NoDecayStatus {
            Text: "Off";
            Style: (FontSize: 11, TextColor: #888888, VerticalAlignment: Center);
            Anchor: (Left: 8);
          }
        }
      }

      // UUID row
      Group {
        LayoutMode: Left;
        Anchor: (Height: 20);

        Label {
          Text: "UUID:";
          Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
          Anchor: (Width: 35);
        }

        Label #UuidValue {
          Text: "";
          Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
        }
      }

      // Spacer
      Label { FlexWeight: 1; }

      // === Bottom Action Buttons ===
      Group #ActionButtons {
        Anchor: (Height: 35);
        LayoutMode: Left;

        TextButton #KickBtn {
          Text: "Kick from Faction";
          Anchor: (Height: 30, Width: 140);
          Style: $S.@RedButtonStyle;
        }

        Label { FlexWeight: 1; }

        TextButton #BackBtn {
          Text: "Back";
          Anchor: (Height: 30, Width: 70);
          Style: $S.@ButtonStyle;
        }
      }
    }
  }
}

$C.@BackButton {}
