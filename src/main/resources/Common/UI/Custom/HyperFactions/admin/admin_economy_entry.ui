// Admin Economy - Faction entry row
// Appended into #FactionList per faction

$S = "../shared/styles.ui";

Group {
  Anchor: (Height: 40, Bottom: 2);
  Background: (Color: #0d1520);
  Padding: (Left: 12, Right: 12, Top: 6, Bottom: 6);
  LayoutMode: Left;

  // Upkeep status indicator (green/yellow/red dot)
  Group #UpkeepDot {
    Visible: false;
    Background: (Color: #55FF55);
    Anchor: (Width: 8, Height: 8);
  }
  Label { Anchor: (Width: 6); }

  Label #FactionName {
    Text: "Faction";
    Style: (FontSize: 12, TextColor: #FFFFFF, VerticalAlignment: Center);
    Anchor: (Width: 150);
  }

  Label #Balance {
    Text: "0";
    Style: (FontSize: 12, TextColor: #FFD700, RenderBold: true, VerticalAlignment: Center);
    Anchor: (Width: 120);
  }

  Label #MemberCount {
    Text: "0";
    Style: (FontSize: 12, TextColor: #888888, VerticalAlignment: Center);
    Anchor: (Width: 80);
  }

  Label { FlexWeight: 1; }

  TextButton #AdjustBtn {
    Text: "Adjust";
    Style: $S.@CyanButtonStyle;
    Anchor: (Height: 26, Width: 70);
  }

  Label { Anchor: (Width: 6); }

  TextButton #ViewBtn {
    Text: "Info";
    Style: $S.@ButtonStyle;
    Anchor: (Height: 26, Width: 55);
  }
}
