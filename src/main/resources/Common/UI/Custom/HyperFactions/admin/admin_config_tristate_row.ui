$C = "../../Common.ui";

Group {
  LayoutMode: Left;
  Anchor: (Height: 24, Bottom: 1);
  Padding: (Left: 18, Right: 4);

  Label #SettingLabel {
    Text: "";
    Style: (FontSize: 11, TextColor: #AAAAAA, VerticalAlignment: Center);
    FlexWeight: 1;
  }

  DropdownBox #TristateSelect {
    Style: $C.@DefaultDropdownBoxStyle;
    Anchor: (Height: 22, Width: 110);
  }
}
