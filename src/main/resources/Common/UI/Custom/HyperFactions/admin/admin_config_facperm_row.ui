$C = "../../Common.ui";

Group {
  LayoutMode: Left;
  Anchor: (Height: 22, Bottom: 3);
  Padding: (Left: 6, Right: 4);

  Label #SettingLabel {
    Text: "";
    Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
    FlexWeight: 1;
  }

  $C.@CheckBoxWithLabel #DefaultToggle {
    @Text = "";
    @Checked = false;
    Anchor: (Height: 20, Width: 36);
  }

  Group { Anchor: (Width: 8); }

  $C.@CheckBoxWithLabel #LockToggle {
    @Text = "";
    @Checked = false;
    Anchor: (Height: 20, Width: 36);
  }
}
