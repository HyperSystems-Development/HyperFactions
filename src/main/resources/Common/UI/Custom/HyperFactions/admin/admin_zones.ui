$C = "../../Common.ui";
$Nav = "admin_nav_bar.ui";

$C.@PageOverlay {
  $Nav.@HyperFactionsAdminNavBar #HyperFactionsAdminNavBar {}

  $C.@Container {
    Anchor: (Width: 700, Height: 500);

    #Title {
      $C.@Title {
        @Text = "Zone Management";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 15, Right: 15, Top: 10, Bottom: 10);

      Group #Tabs {
        Anchor: (Height: 35, Bottom: 10);
        LayoutMode: Left;

        TextButton #TabAll {
          Text: "All";
          Anchor: (Height: 26, Width: 50);
          Style: $C.@SecondaryTextButtonStyle;
        }

        Label { Anchor: (Width: 5); }

        TextButton #TabSafe {
          Text: "Safe";
          Anchor: (Height: 26, Width: 60);
          Style: $C.@SecondaryTextButtonStyle;
        }

        Label { Anchor: (Width: 5); }

        TextButton #TabWar {
          Text: "War";
          Anchor: (Height: 26, Width: 55);
          Style: $C.@CancelTextButtonStyle;
        }

        Label { FlexWeight: 1; }

        TextButton #CreateZoneBtn {
          Text: "+ Create";
          Anchor: (Height: 26, Width: 90);
          Style: $C.@SecondaryTextButtonStyle;
        }
      }

      Group {
        Anchor: (Height: 1, Bottom: 8);
        Background: (Color: #00AAAA);
      }

      // Header row with zone count and sort
      Group {
        Anchor: (Height: 35, Bottom: 8);
        LayoutMode: Left;

        Label #ZoneCount {
          Text: "0 zones";
          Style: (FontSize: 13, TextColor: #888888, VerticalAlignment: Center);
          Anchor: (Width: 200);
        }

        Group { FlexWeight: 1; }

        Label {
          Text: "Sort:";
          Style: (FontSize: 11, TextColor: #888888, VerticalAlignment: Center);
          Anchor: (Width: 35);
        }
        DropdownBox #SortDropdown {
          Style: $C.@DefaultDropdownBoxStyle;
          Anchor: (Height: 28, Width: 130);
        }
      }

      Group #ZoneListContainer {
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        FlexWeight: 1;

        Group #ZoneList {
          LayoutMode: Top;
        }
      }

      Group {
        Anchor: (Height: 1, Top: 8, Bottom: 8);
        Background: (Color: #00AAAA);
      }

      Group #Pagination {
        Anchor: (Height: 35);
        LayoutMode: Left;

        TextButton #PrevBtn {
          Text: "< Prev";
          Anchor: (Height: 26, Width: 80);
          Style: $C.@SecondaryTextButtonStyle;
        }

        Label { FlexWeight: 1; }

        Label #PageInfo {
          Text: "1/1";
          Style: (FontSize: 14, TextColor: #888888, HorizontalAlignment: Center, VerticalAlignment: Center);
          Anchor: (Width: 60);
        }

        Label { FlexWeight: 1; }

        TextButton #NextBtn {
          Text: "Next >";
          Anchor: (Height: 26, Width: 80);
          Style: $C.@SecondaryTextButtonStyle;
        }
      }
    }
  }
}

$C.@BackButton {}
