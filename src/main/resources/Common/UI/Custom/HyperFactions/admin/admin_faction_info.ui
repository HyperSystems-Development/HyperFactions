// Admin Faction Info Page
// Two-column layout: stats (full width), then Left = leadership/info, Right = controls
// Back button returns to AdminFactionsPage

$C = "../../Common.ui";
$S = "../shared/styles.ui";
$Nav = "admin_nav_bar.ui";

$C.@PageOverlay {
  $Nav.@HyperFactionsAdminNavBar #HyperFactionsAdminNavBar {}

  $C.@Container {
    Anchor: (Width: 640, Height: 600);

    #Title {
      $C.@Title {
        @Text = "Admin: Faction Info";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 20, Right: 20, Top: 12, Bottom: 12);

      // === Header Section (full width) ===
      Group #HeaderSection {
        Anchor: (Height: 55, Bottom: 8);
        LayoutMode: Top;

        // Faction name, tag, and status row
        Group {
          LayoutMode: Left;
          Anchor: (Height: 28);

          Label #FactionName {
            Text: "Faction Name";
            Style: (FontSize: 18, TextColor: #00FFFF, RenderBold: true, VerticalAlignment: Center);
          }

          Label #FactionTag {
            Text: "";
            Style: (FontSize: 14, TextColor: #FFD700, RenderBold: true, VerticalAlignment: Center);
            Anchor: (Left: 8);
          }

          Label { FlexWeight: 1; }

          Label #StatusIndicator {
            Text: "";
            Style: (FontSize: 12, TextColor: #44cc44, RenderBold: true, VerticalAlignment: Center);
          }
        }

        // Description
        Label #FactionDescription {
          Text: "No description set.";
          Style: (FontSize: 12, TextColor: #888888);
          Anchor: (Height: 20);
        }
      }

      // === Stats Row 1: Power, Claims, Members (full width) ===
      Group #StatsRow1 {
        Anchor: (Height: 70, Bottom: 6);
        LayoutMode: Left;

        // Power card
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 10, Right: 10, Top: 6, Bottom: 6);
          LayoutMode: Top;
          Anchor: (Right: 4);

          Label #PowerCardLabel {
            Text: "Power";
            Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
          Label #PowerValue {
            Text: "0.0 / 0.0";
            Style: (FontSize: 18, TextColor: #44CC44, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            FlexWeight: 1;
          }
          Label #PowerSubLabel {
            Text: "current / max";
            Style: (FontSize: 9, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }

        // Claims card
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 10, Right: 10, Top: 6, Bottom: 6);
          LayoutMode: Top;
          Anchor: (Left: 4, Right: 4);

          Label #ClaimsCardLabel {
            Text: "Claims";
            Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
          Label #ClaimsValue {
            Text: "0 / 0";
            Style: (FontSize: 18, TextColor: #FFAA00, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            FlexWeight: 1;
          }
          Label #ClaimsSubLabel {
            Text: "claimed / max";
            Style: (FontSize: 9, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }

        // Members card
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 10, Right: 10, Top: 6, Bottom: 6);
          LayoutMode: Top;
          Anchor: (Left: 4);

          Label #MembersCardLabel {
            Text: "Members";
            Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
          Label #MembersValue {
            Text: "0 / 0";
            Style: (FontSize: 18, TextColor: #00FFFF, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            FlexWeight: 1;
          }
          Label #RecruitmentValue {
            Text: "Invite Only";
            Style: (FontSize: 9, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }
      }

      // === Stats Row 2: Relations, Status, Info/Treasury (full width) ===
      Group #StatsRow2 {
        Anchor: (Height: 70, Bottom: 8);
        LayoutMode: Left;

        // Relations card (ally / enemy split)
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 10, Right: 10, Top: 6, Bottom: 6);
          LayoutMode: Top;
          Anchor: (Right: 4);

          Label #RelationsCardLabel {
            Text: "Relations";
            Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
          Group {
            FlexWeight: 1;
            LayoutMode: Left;

            Label #AlliesValue {
              Text: "0";
              Style: (FontSize: 16, TextColor: #55FF55, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
              FlexWeight: 1;
            }
            Label {
              Text: "/";
              Style: (FontSize: 14, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
              Anchor: (Width: 15);
            }
            Label #EnemiesValue {
              Text: "0";
              Style: (FontSize: 16, TextColor: #FF5555, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
              FlexWeight: 1;
            }
          }
          Label #RelationsSubLabel {
            Text: "ally / enemy";
            Style: (FontSize: 9, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }

        // Status card (raidable status + founded)
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 10, Right: 10, Top: 6, Bottom: 6);
          LayoutMode: Top;
          Anchor: (Left: 4, Right: 4);

          Label #StatusCardLabel {
            Text: "Status";
            Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
          Label #RaidableValue {
            Text: "Protected";
            Style: (FontSize: 16, TextColor: #44cc44, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            FlexWeight: 1;
          }
          Label #FoundedValue {
            Text: "Unknown";
            Style: (FontSize: 9, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }

        // Info / Treasury card
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 10, Right: 10, Top: 6, Bottom: 6);
          LayoutMode: Top;
          Anchor: (Left: 4);

          Label #InfoCardLabel {
            Text: "Info";
            Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }

          // Treasury row (hidden when economy disabled, shown by Java)
          Group #TreasuryRow {
            FlexWeight: 1;
            LayoutMode: Top;
            Visible: false;

            Label #TreasuryValue {
              Text: "0";
              Style: (FontSize: 18, TextColor: #FFD700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
              FlexWeight: 1;
            }
            Label #TreasurySubLabel {
              Text: "treasury balance";
              Style: (FontSize: 9, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
              Anchor: (Height: 14);
            }
          }
        }
      }

      // Cyan divider
      Group {
        Anchor: (Height: 1, Bottom: 8);
        Background: (Color: #00AAAA);
      }

      // === Two-Column Body ===
      Group #TwoColumnBody {
        FlexWeight: 1;
        LayoutMode: Left;
        Anchor: (Bottom: 8);

        // === LEFT COLUMN — Leadership & Info ===
        Group #LeftColumn {
          Anchor: (Width: 280);
          LayoutMode: Top;
          Padding: (Right: 10);

          // Leadership Card
          Group #LeadershipSection {
            Background: (Color: #1a2a3a);
            Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
            LayoutMode: Top;

            Label #LeadershipHeader {
              Text: "Leadership";
              Style: (FontSize: 11, TextColor: #666666, RenderBold: true);
              Anchor: (Height: 16, Bottom: 6);
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 22, Bottom: 4);

              Label #LeaderLabel {
                Text: "Leader:";
                Style: (FontSize: 12, TextColor: #FFD700, RenderBold: true, VerticalAlignment: Center);
                Anchor: (Width: 60);
              }
              Label #LeaderName {
                Text: "Unknown";
                Style: (FontSize: 12, TextColor: #FFFFFF, VerticalAlignment: Center);
              }
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 22);

              Label #OfficersLabel {
                Text: "Officers:";
                Style: (FontSize: 12, TextColor: #87CEEB, RenderBold: true, VerticalAlignment: Center);
                Anchor: (Width: 60);
              }
              Label #OfficersValue {
                Text: "None";
                Style: (FontSize: 12, TextColor: #FFFFFF, VerticalAlignment: Center);
              }
            }
          }
        }

        // === RIGHT COLUMN — Controls ===
        Group #RightColumn {
          FlexWeight: 1;
          LayoutMode: Top;
          Padding: (Left: 10);

          // Power Management
          Group {
            Background: (Color: #1a2a3a);
            Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
            LayoutMode: Top;
            Anchor: (Bottom: 6);

            Label #PowerMgmtHeader {
              Text: "Power Management";
              Style: (FontSize: 11, TextColor: #666666, RenderBold: true);
              Anchor: (Height: 16, Bottom: 6);
            }

            Group #PowerManagement {
              Anchor: (Height: 30, Bottom: 6);
              LayoutMode: Left;

              TextButton #PowerSubFive {
                Text: "-5 All";
                Anchor: (Height: 26, Width: 52, Right: 3);
                Style: $S.@RedButtonStyle;
              }

              TextButton #PowerSubOne {
                Text: "-1 All";
                Anchor: (Height: 26, Width: 52, Right: 3);
                Style: $S.@RedButtonStyle;
              }

              TextButton #PowerAddOne {
                Text: "+1 All";
                Anchor: (Height: 26, Width: 52, Right: 3);
                Style: $S.@ButtonStyle;
              }

              TextButton #PowerAddFive {
                Text: "+5 All";
                Anchor: (Height: 26, Width: 52);
                Style: $S.@ButtonStyle;
              }
            }

            Group {
              Anchor: (Height: 30);
              LayoutMode: Left;

              TextButton #PowerResetAll {
                Text: "Reset All Power";
                Anchor: (Height: 26, Width: 130);
                Style: $S.@CyanButtonStyle;
              }
            }
          }

          // Economy Management Section (hidden when economy disabled)
          Group #EconomyManagement {
            Background: (Color: #1a2a3a);
            Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
            LayoutMode: Top;
            Visible: false;
            Anchor: (Bottom: 6);

            Label #EconMgmtHeader {
              Text: "Economy Management";
              Style: (FontSize: 11, TextColor: #666666, RenderBold: true);
              Anchor: (Height: 16, Bottom: 6);
            }

            Group {
              Anchor: (Height: 30);
              LayoutMode: Left;

              TextButton #EconAdjustBtn {
                Text: "Adjust Balance";
                Anchor: (Height: 26, Width: 115, Right: 6);
                Style: $S.@CyanButtonStyle;
              }

              TextButton #EconViewLogBtn {
                Text: "View Treasury";
                Anchor: (Height: 26, Width: 115);
                Style: $S.@ButtonStyle;
              }
            }
          }

          // Danger Zone
          Group {
            Background: (Color: #2a1a1a);
            Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
            LayoutMode: Top;

            Label #DangerZoneHeader {
              Text: "Danger Zone";
              Style: (FontSize: 11, TextColor: #FF5555, RenderBold: true);
              Anchor: (Height: 16, Bottom: 6);
            }

            TextButton #DisbandBtn {
              Text: "Disband Faction";
              Anchor: (Height: 26);
              Style: $S.@RedButtonStyle;
            }
          }
        }
      }

      // === Bottom Action Buttons (full width) ===
      Group #ActionButtons {
        Anchor: (Height: 35);
        LayoutMode: Left;

        TextButton #ViewMembersBtn {
          Text: "Members";
          Anchor: (Height: 30, Width: 85);
          Style: $S.@ButtonStyle;
        }

        Label { Anchor: (Width: 6); }

        TextButton #ViewRelationsBtn {
          Text: "Relations";
          Anchor: (Height: 30, Width: 85);
          Style: $S.@ButtonStyle;
        }

        Label { Anchor: (Width: 6); }

        TextButton #ViewSettingsBtn {
          Text: "Settings";
          Anchor: (Height: 30, Width: 85);
          Style: $S.@ButtonStyle;
        }

        Label { FlexWeight: 1; }

        TextButton #BackBtn {
          Text: "Back";
          Anchor: (Height: 30, Width: 70);
          Style: $S.@ButtonStyle;
        }
      }
    }
  }
}

$C.@BackButton {}
