// Admin Faction Info Page
// Card-based stat layout matching admin dashboard and faction dashboard style
// Back button returns to AdminFactionsPage

$C = "../../Common.ui";
$Nav = "admin_nav_bar.ui";

$C.@PageOverlay {
  $Nav.@HyperFactionsAdminNavBar #HyperFactionsAdminNavBar {}

  $C.@Container {
    Anchor: (Width: 580, Height: 600);

    #Title {
      $C.@Title {
        @Text = "Admin: Faction Info";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 20, Right: 20, Top: 12, Bottom: 12);

      // === Header Section ===
      Group #HeaderSection {
        Anchor: (Height: 55, Bottom: 8);
        LayoutMode: Top;

        // Faction name, tag, and status row
        Group {
          LayoutMode: Left;
          Anchor: (Height: 28);

          Label #FactionName {
            Text: "Faction Name";
            Style: (FontSize: 18, TextColor: #00FFFF, RenderBold: true, VerticalAlignment: Center);
          }

          Label #FactionTag {
            Text: "";
            Style: (FontSize: 14, TextColor: #FFD700, RenderBold: true, VerticalAlignment: Center);
            Anchor: (Left: 8);
          }

          Label { FlexWeight: 1; }

          Label #StatusIndicator {
            Text: "";
            Style: (FontSize: 12, TextColor: #44cc44, RenderBold: true, VerticalAlignment: Center);
          }
        }

        // Description
        Label #FactionDescription {
          Text: "No description set.";
          Style: (FontSize: 12, TextColor: #888888);
          Anchor: (Height: 20);
        }
      }

      // === Stats Row 1: Power, Claims, Members ===
      Group #StatsRow1 {
        Anchor: (Height: 75, Bottom: 8);
        LayoutMode: Left;

        // Power card
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Right: 4);

          Label {
            Text: "Power";
            Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
          Label #PowerValue {
            Text: "0.0 / 0.0";
            Style: (FontSize: 20, TextColor: #44CC44, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            FlexWeight: 1;
          }
          Label {
            Text: "current / max";
            Style: (FontSize: 9, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }

        // Claims card
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4, Right: 4);

          Label {
            Text: "Claims";
            Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
          Label #ClaimsValue {
            Text: "0 / 0";
            Style: (FontSize: 20, TextColor: #FFAA00, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            FlexWeight: 1;
          }
          Label {
            Text: "claimed / max";
            Style: (FontSize: 9, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }

        // Members card
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4);

          Label {
            Text: "Members";
            Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
          Label #MembersValue {
            Text: "0 / 0";
            Style: (FontSize: 20, TextColor: #00FFFF, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            FlexWeight: 1;
          }
          Label #RecruitmentValue {
            Text: "Invite Only";
            Style: (FontSize: 9, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }
      }

      // === Stats Row 2: Relations, Status, Info/Treasury ===
      Group #StatsRow2 {
        Anchor: (Height: 75, Bottom: 10);
        LayoutMode: Left;

        // Relations card (ally / enemy split)
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Right: 4);

          Label {
            Text: "Relations";
            Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
          Group {
            FlexWeight: 1;
            LayoutMode: Left;

            Label #AlliesValue {
              Text: "0";
              Style: (FontSize: 18, TextColor: #55FF55, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
              FlexWeight: 1;
            }
            Label {
              Text: "/";
              Style: (FontSize: 14, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
              Anchor: (Width: 15);
            }
            Label #EnemiesValue {
              Text: "0";
              Style: (FontSize: 18, TextColor: #FF5555, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
              FlexWeight: 1;
            }
          }
          Label {
            Text: "ally / enemy";
            Style: (FontSize: 9, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }

        // Status card (raidable status + founded)
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4, Right: 4);

          Label {
            Text: "Status";
            Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
          Label #RaidableValue {
            Text: "Protected";
            Style: (FontSize: 18, TextColor: #44cc44, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            FlexWeight: 1;
          }
          Label #FoundedValue {
            Text: "Unknown";
            Style: (FontSize: 9, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }

        // Info / Treasury card
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4);

          Label {
            Text: "Info";
            Style: (FontSize: 9, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }

          // Treasury row (hidden when economy disabled, shown by Java)
          Group #TreasuryRow {
            FlexWeight: 1;
            LayoutMode: Top;
            Visible: false;

            Label #TreasuryValue {
              Text: "0";
              Style: (FontSize: 20, TextColor: #FFD700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
              FlexWeight: 1;
            }
            Label {
              Text: "treasury balance";
              Style: (FontSize: 9, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
              Anchor: (Height: 14);
            }
          }
        }
      }

      // Cyan divider
      Group {
        Anchor: (Height: 1, Bottom: 8);
        Background: (Color: #00AAAA);
      }

      // === Leadership Card ===
      Group #LeadershipSection {
        Anchor: (Height: 50, Bottom: 8);
        Background: (Color: #1a2a3a);
        Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
        LayoutMode: Left;

        Label {
          Text: "Leader:";
          Style: (FontSize: 12, TextColor: #FFD700, RenderBold: true, VerticalAlignment: Center);
          Anchor: (Width: 65);
        }

        Label #LeaderName {
          Text: "Unknown";
          Style: (FontSize: 12, TextColor: #FFFFFF, VerticalAlignment: Center);
        }

        Label { Anchor: (Width: 30); }

        Label {
          Text: "Officers:";
          Style: (FontSize: 12, TextColor: #87CEEB, RenderBold: true, VerticalAlignment: Center);
          Anchor: (Width: 70);
        }

        Label #OfficersValue {
          Text: "None";
          Style: (FontSize: 12, TextColor: #FFFFFF, VerticalAlignment: Center);
        }
      }

      // Cyan divider
      Group {
        Anchor: (Height: 1, Bottom: 8);
        Background: (Color: #00AAAA);
      }

      // === Power Management Section ===
      Group {
        Anchor: (Height: 20, Bottom: 5);
        Label {
          Text: "Power Management";
          Style: (FontSize: 11, TextColor: #666666, RenderBold: true);
        }
      }

      Group #PowerManagement {
        Anchor: (Height: 30, Bottom: 8);
        LayoutMode: Left;

        TextButton #PowerSubFive {
          Text: "-5 All";
          Anchor: (Height: 26, Width: 55, Right: 4);
          Style: $C.@CancelTextButtonStyle;
        }

        TextButton #PowerSubOne {
          Text: "-1 All";
          Anchor: (Height: 26, Width: 55, Right: 4);
          Style: $C.@CancelTextButtonStyle;
        }

        TextButton #PowerAddOne {
          Text: "+1 All";
          Anchor: (Height: 26, Width: 55, Right: 4);
          Style: $C.@SecondaryTextButtonStyle;
        }

        TextButton #PowerAddFive {
          Text: "+5 All";
          Anchor: (Height: 26, Width: 55, Right: 8);
          Style: $C.@SecondaryTextButtonStyle;
        }

        TextButton #PowerResetAll {
          Text: "Reset All";
          Anchor: (Height: 26, Width: 75);
          Style: $C.@SecondaryTextButtonStyle;
        }
      }

      // === Economy Management Section (hidden when economy disabled) ===
      Group #EconomyManagement {
        Anchor: (Height: 55);
        LayoutMode: Top;
        Visible: false;

        Group {
          Anchor: (Height: 20, Bottom: 5);
          Label {
            Text: "Economy Management";
            Style: (FontSize: 11, TextColor: #666666, RenderBold: true);
          }
        }

        Group {
          Anchor: (Height: 30);
          LayoutMode: Left;

          TextButton #EconAdjustBtn {
            Text: "Adjust Balance";
            Anchor: (Height: 26, Width: 120, Right: 8);
            Style: $C.@SecondaryTextButtonStyle;
          }

          TextButton #EconViewLogBtn {
            Text: "View Treasury";
            Anchor: (Height: 26, Width: 120);
            Style: $C.@SecondaryTextButtonStyle;
          }
        }
      }

      // Spacer to push buttons to bottom
      Label { FlexWeight: 1; }

      // === Bottom Action Buttons ===
      Group #ActionButtons {
        Anchor: (Height: 35);
        LayoutMode: Left;

        TextButton #ViewMembersBtn {
          Text: "Members";
          Anchor: (Height: 30, Width: 90);
          Style: $C.@SecondaryTextButtonStyle;
        }

        Label { Anchor: (Width: 8); }

        TextButton #ViewRelationsBtn {
          Text: "Relations";
          Anchor: (Height: 30, Width: 95);
          Style: $C.@SecondaryTextButtonStyle;
        }

        Label { Anchor: (Width: 8); }

        TextButton #ViewSettingsBtn {
          Text: "Settings";
          Anchor: (Height: 30, Width: 90);
          Style: $C.@SecondaryTextButtonStyle;
        }

        Label { FlexWeight: 1; }

        TextButton #BackBtn {
          Text: "Back";
          Anchor: (Height: 30, Width: 70);
          Style: $C.@SecondaryTextButtonStyle;
        }
      }
    }
  }
}

$C.@BackButton {}
