$C = "../../Common.ui";
$S = "../shared/styles.ui";

Group {
  LayoutMode: Left;
  Anchor: (Height: 24, Bottom: 3);
  Padding: (Left: 6, Right: 4);

  Label #SettingLabel {
    Text: "";
    Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
    FlexWeight: 1;
  }

  DropdownBox #EnumSelect {
    Style: $C.@DefaultDropdownBoxStyle;
    Anchor: (Height: 24, Width: 140);
  }
}
