// Admin Player Entry - Expandable row for server-wide player list
$C = "../../Common.ui";
$S = "../shared/styles.ui";

Group {
  LayoutMode: Top;
  Anchor: (Bottom: 4);

  // Header wrapper - contains content and clickable overlay
  Group #HeaderWrapper {
    Anchor: (Height: 44);

    // Header content (visual layout)
    Group #HeaderContent {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: (Color: #1a2a3a);
      Padding: (Left: 12, Right: 12, Top: 6, Bottom: 6);
      LayoutMode: Left;

      // Online indicator bar
      Group #OnlineBar {
        Anchor: (Width: 3, Top: 4, Bottom: 4);
        Background: (Color: #888888);
      }

      Group { Anchor: (Width: 10); }

      // Player name
      Group {
        Anchor: (Width: 180);
        LayoutMode: Top;

        Label #PlayerName {
          Text: "PlayerName";
          Style: (FontSize: 13, TextColor: #CCCCCC, RenderBold: true, VerticalAlignment: Center);
          Anchor: (Height: 18);
        }
        Label #OnlineStatus {
          Text: "Offline";
          Style: (FontSize: 10, TextColor: #888888, VerticalAlignment: Center);
          Anchor: (Height: 14);
        }
      }

      // Faction name
      Label #FactionName {
        Text: "No Faction";
        Style: (FontSize: 11, TextColor: #666666, VerticalAlignment: Center);
        Anchor: (Width: 140);
      }

      // Power display
      Label #PowerDisplay {
        Text: "0/0";
        Style: (FontSize: 11, TextColor: #55FF55, VerticalAlignment: Center, HorizontalAlignment: Center);
        Anchor: (Width: 90);
      }

      Group { FlexWeight: 1; }

      // Expand indicators
      Label #ExpandIcon {
        Text: ">";
        Style: (FontSize: 14, TextColor: #666666, VerticalAlignment: Center, HorizontalAlignment: Center);
        Anchor: (Width: 20);
      }
      Label #CollapseIcon {
        Text: "v";
        Style: (FontSize: 14, TextColor: #00AAAA, VerticalAlignment: Center, HorizontalAlignment: Center);
        Anchor: (Width: 20);
      }
    }

    // Clickable overlay button
    TextButton #Header {
      Text: "";
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Style: $S.@InvisibleButtonStyle;
    }
  }

  // Expanded content
  Group #ExtendedInfo {
    LayoutMode: Top;
    Background: (Color: #0d1520);
    Padding: (Left: 25, Right: 12, Top: 8, Bottom: 10);

    // Stats row
    Group #StatsRow {
      LayoutMode: Left;
      Anchor: (Height: 20, Bottom: 4);

      Label {
        Text: "Role:";
        Style: (FontSize: 10, TextColor: #666666, VerticalAlignment: Center);
        Anchor: (Width: 35);
      }
      Label #RoleValue {
        Text: "N/A";
        Style: (FontSize: 10, TextColor: #888888, VerticalAlignment: Center);
        Anchor: (Width: 70);
      }

      Label {
        Text: "Joined:";
        Style: (FontSize: 10, TextColor: #666666, VerticalAlignment: Center);
        Anchor: (Width: 45);
      }
      Label #JoinedDate {
        Text: "Unknown";
        Style: (FontSize: 10, TextColor: #888888, VerticalAlignment: Center);
        Anchor: (Width: 80);
      }

      Label {
        Text: "Last Online:";
        Style: (FontSize: 10, TextColor: #666666, VerticalAlignment: Center);
        Anchor: (Width: 70);
      }
      Label #LastOnline {
        Text: "Unknown";
        Style: (FontSize: 10, TextColor: #888888, VerticalAlignment: Center);
        FlexWeight: 1;
      }
    }

    // Combat stats row
    Group #CombatRow {
      LayoutMode: Left;
      Anchor: (Height: 20, Bottom: 4);

      Label {
        Text: "K/D/R:";
        Style: (FontSize: 10, TextColor: #666666, VerticalAlignment: Center);
        Anchor: (Width: 40);
      }
      Label #KdrValue {
        Text: "0/0/0.00";
        Style: (FontSize: 10, TextColor: #888888, VerticalAlignment: Center);
        Anchor: (Width: 100);
      }

      Label {
        Text: "Power:";
        Style: (FontSize: 10, TextColor: #666666, VerticalAlignment: Center);
        Anchor: (Width: 45);
      }
      Label #PowerDetail {
        Text: "0.0/0.0";
        Style: (FontSize: 10, TextColor: #55FF55, VerticalAlignment: Center);
        Anchor: (Width: 80);
      }
    }

    // UUID row
    Group #UuidRow {
      LayoutMode: Left;
      Anchor: (Height: 18, Bottom: 8);

      Label {
        Text: "UUID:";
        Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
        Anchor: (Width: 40);
      }
      Label #UuidValue {
        Text: "00000000-0000-0000-0000-000000000000";
        Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
        FlexWeight: 1;
      }
    }

    // Action buttons row
    Group #ActionsRow {
      LayoutMode: Left;
      Anchor: (Height: 28);

      TextButton #ViewInfoBtn {
        Text: "Info";
        Anchor: (Height: 24, Width: 60, Right: 6);
        Style: $S.@CyanButtonStyle;
      }
      TextButton #TeleportBtn {
        Text: "Teleport";
        Anchor: (Height: 24, Width: 80, Right: 6);
        Style: $S.@ButtonStyle;
      }
      Group { FlexWeight: 1; }
    }
  }
}
