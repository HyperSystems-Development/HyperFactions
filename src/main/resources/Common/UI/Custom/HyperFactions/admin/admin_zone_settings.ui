        // ===== RIGHT COLUMN (Transport, Items, Spawning) =====
        Group #RightColumn {
          FlexWeight: 1;
          LayoutMode: Top;
          Padding: (Left: 5, Right: 0, Top: 0, Bottom: 0);

          // --- Transport Box ---
