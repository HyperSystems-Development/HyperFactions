              $C.@CheckBoxWithLabel #Flag24Toggle {
                @Text = ""; @Checked = true;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 25: item_pickup (auto)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Label #Flag25Name {
                Text: "Auto Pickup";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 110);
              }
              Label { FlexWeight: 1; }
              Label #Flag25Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag25Toggle {
                @Text = ""; @Checked = true;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 26: item_pickup_manual (F-key, mixin: pickup)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Label #Flag26Name {
                Text: "F-Key Pickup";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 110);
              }
              Label { FlexWeight: 1; }
              Label #Flag26Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag26Toggle {
                @Text = ""; @Checked = true;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 27: invincible_items (mixin: durability)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Label #Flag27Name {
                Text: "Invincible Items";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 110);
              }
              Label { FlexWeight: 1; }
              Label #Flag27Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag27Toggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }
          }

          // --- Mob Spawning Box ---
          Group #SpawningBox {
            Background: (Color: #1a2a3a);
            Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
            LayoutMode: Top;
            Anchor: (Bottom: 0);

            Group {
              Anchor: (Height: 18, Bottom: 0);
              Label {
                Text: "Mob Spawning";
                Style: (FontSize: 11, TextColor: #00AAAA, RenderBold: true);
              }
            }
            Group {
              Anchor: (Height: 12, Bottom: 4);
              Label {
                Text: "(children only apply when parent ON)";
                Style: (FontSize: 8, TextColor: #666666);
              }
            }

            // Flag 28: mob_spawning (parent, mixin: spawn)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Label #Flag28Name {
                Text: "Mob Spawning";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 110);
              }
              Label { FlexWeight: 1; }
              Label #Flag28Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag28Toggle {
                @Text = ""; @Checked = true;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 29: hostile_mob_spawning (child)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Padding: (Left: 12, Right: 0, Top: 0, Bottom: 0);
              Label #Flag29Name {
                Text: "Hostile Mobs";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 98);
              }
              Label { FlexWeight: 1; }
              Label #Flag29Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag29Toggle {
                @Text = ""; @Checked = true;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 30: passive_mob_spawning (child)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Padding: (Left: 12, Right: 0, Top: 0, Bottom: 0);
              Label #Flag30Name {
                Text: "Passive Mobs";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 98);
              }
              Label { FlexWeight: 1; }
              Label #Flag30Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag30Toggle {
                @Text = ""; @Checked = true;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 31: neutral_mob_spawning (child)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Padding: (Left: 12, Right: 0, Top: 0, Bottom: 0);
              Label #Flag31Name {
                Text: "Neutral Mobs";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 98);
              }
              Label { FlexWeight: 1; }
              Label #Flag31Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag31Toggle {
                @Text = ""; @Checked = true;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 32: npc_spawning (child, mixin: spawn)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Padding: (Left: 12, Right: 0, Top: 0, Bottom: 0);
              Label #Flag32Name {
                Text: "NPC Spawning";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 98);
              }
              Label { FlexWeight: 1; }
              Label #Flag32Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag32Toggle {
                @Text = ""; @Checked = true;
                Anchor: (Height: 20, Width: 44);
              }
            }
          }

        }
      }

      // === Footer ===
      Group #Footer {
        Anchor: (Height: 40);
        LayoutMode: Left;

        TextButton #ResetBtn {
          Text: "Reset to Defaults";
          Anchor: (Height: 32, Width: 150);
          Style: $S.@RedButtonStyle;
        }

        Label { FlexWeight: 1; }

        TextButton #IntegrationFlagsBtn {
          Text: "Integration Flags";
          Anchor: (Height: 32, Width: 160);
          Style: $S.@ButtonStyle;
        }

        Label { FlexWeight: 1; }

        TextButton #BackBtn {
          Text: "Back to Zones";
          Anchor: (Height: 32, Width: 130);
          Style: $S.@ButtonStyle;
        }
      }
    }
  }
}

$C.@BackButton {}
