// Admin Zone Settings Page
// Configure zone flags visually
// Shows all 36 core flags with toggle buttons in 3-column layout with boxes
// Integration flags are on a separate sub-page (admin_zone_integration_flags.ui)
// Mixin-dependent flags show "(mixin)" when unavailable

$C = "../../Common.ui";
$S = "../shared/styles.ui";
$Nav = "admin_nav_bar.ui";

$C.@PageOverlay {
  $Nav.@HyperFactionsAdminNavBar #HyperFactionsAdminNavBar {}

  $C.@DecoratedContainer {
    Anchor: (Width: 880, Height: 680);

    #Title {
      Group {
        $C.@Title {
          @Text = "Admin: Zone Settings";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 20, Right: 20, Top: 12, Bottom: 12);

      // === Zone Info Header ===
      Group #HeaderSection {
        Anchor: (Height: 32, Bottom: 8);
        LayoutMode: Left;

        Label #ZoneName {
          Text: "Zone Name";
          Style: (FontSize: 16, TextColor: #00FFFF, RenderBold: true, VerticalAlignment: Center);
        }

        Label { Anchor: (Width: 12); }

        Label #ZoneType {
          Text: "Safe";
          Style: (FontSize: 12, TextColor: #2dd4bf, RenderBold: true, VerticalAlignment: Center);
        }

        Label { Anchor: (Width: 12); }

        Label #ZoneChunks {
          Text: "0 chunks";
          Style: (FontSize: 11, TextColor: #888888, VerticalAlignment: Center);
        }
      }

      // Divider
      Group {
        Anchor: (Height: 1, Bottom: 8);
        Background: (Color: #00AAAA);
      }

      // === Three-Column Layout ===
      Group #FlagsContainer {
        LayoutMode: Left;
        FlexWeight: 1;

        // ===== LEFT COLUMN (Combat, Damage, Death) =====
        Group #LeftColumn {
          FlexWeight: 1;
          LayoutMode: Top;
          Padding: (Left: 0, Right: 5, Top: 0, Bottom: 0);

          // --- Combat Box ---
          Group #CombatBox {
            Background: (Color: #1a2a3a);
            Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
            LayoutMode: Top;
            Anchor: (Bottom: 8);

            Group {
              Anchor: (Height: 18, Bottom: 0);
              Label {
                Text: "Combat";
                Style: (FontSize: 11, TextColor: #00AAAA, RenderBold: true);
              }
            }
            Group {
              Anchor: (Height: 12, Bottom: 4);
              Label {
                Text: "(children only apply when parent ON)";
                Style: (FontSize: 8, TextColor: #666666);
              }
            }

            // Flag 0: pvp_enabled (parent)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Label #Flag0Name {
                Text: "PvP Enabled";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 110);
              }
              Label { FlexWeight: 1; }
              Label #Flag0Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag0Toggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 1: friendly_fire (child of PvP, parent of faction/ally)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Padding: (Left: 12, Right: 0, Top: 0, Bottom: 0);
              Label #Flag1Name {
                Text: "Friendly Fire";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 98);
              }
              Label { FlexWeight: 1; }
              Label #Flag1Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag1Toggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 2: friendly_fire_faction (grandchild)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Padding: (Left: 24, Right: 0, Top: 0, Bottom: 0);
              Label #Flag2Name {
                Text: "Faction Dmg";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 86);
              }
              Label { FlexWeight: 1; }
              Label #Flag2Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag2Toggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 3: friendly_fire_ally (grandchild)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Padding: (Left: 24, Right: 0, Top: 0, Bottom: 0);
              Label #Flag3Name {
                Text: "Ally Dmg";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 86);
              }
              Label { FlexWeight: 1; }
              Label #Flag3Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag3Toggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 4: projectile_damage
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Label #Flag4Name {
                Text: "Projectile Dmg";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 110);
              }
              Label { FlexWeight: 1; }
              Label #Flag4Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag4Toggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 5: mob_damage
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Label #Flag5Name {
                Text: "Mob Damage";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 110);
              }
              Label { FlexWeight: 1; }
              Label #Flag5Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag5Toggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }
          }

          // --- Damage Box ---
          Group #DamageBox {
            Background: (Color: #1a2a3a);
            Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
            LayoutMode: Top;
            Anchor: (Bottom: 8);

            Group {
              Anchor: (Height: 18, Bottom: 4);
              Label {
                Text: "Damage";
                Style: (FontSize: 11, TextColor: #00AAAA, RenderBold: true);
              }
            }

            // Flag 6: fall_damage
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Label #Flag6Name {
                Text: "Fall Damage";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 110);
              }
              Label { FlexWeight: 1; }
              Label #Flag6Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag6Toggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 7: environmental_damage
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Label #Flag7Name {
                Text: "Environment";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 110);
              }
              Label { FlexWeight: 1; }
              Label #Flag7Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag7Toggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 8: explosion_damage (mixin: explosion)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Label #Flag8Name {
                Text: "Explosion Dmg";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 110);
              }
              Label { FlexWeight: 1; }
              Label #Flag8Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag8Toggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 9: fire_spread (mixin: fire_spread)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Label #Flag9Name {
                Text: "Fire Spread";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 110);
              }
              Label { FlexWeight: 1; }
              Label #Flag9Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag9Toggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }
          }

          // --- Death Box (mixin-dependent) ---
          Group #DeathBox {
            Background: (Color: #1a2a3a);
            Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
            LayoutMode: Top;
            Anchor: (Bottom: 0);

            Group {
              Anchor: (Height: 18, Bottom: 4);
              Label {
                Text: "Death";
                Style: (FontSize: 11, TextColor: #00AAAA, RenderBold: true);
              }
            }

            // Flag 10: keep_inventory (mixin: death)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Label #Flag10Name {
                Text: "Keep Inventory";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 110);
              }
              Label { FlexWeight: 1; }
              Label #Flag10Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag10Toggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 11: power_loss
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Label #Flag11Name {
                Text: "Power Loss";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 110);
              }
              Label { FlexWeight: 1; }
              Label #Flag11Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag11Toggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }
          }
        }

        // ===== MIDDLE COLUMN (Building, Interaction, Entity Interaction) =====
        Group #MiddleColumn {
          FlexWeight: 1;
          LayoutMode: Top;
          Padding: (Left: 5, Right: 5, Top: 0, Bottom: 0);

          // --- Building Box ---
          Group #BuildingBox {
            Background: (Color: #1a2a3a);
            Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
            LayoutMode: Top;
            Anchor: (Bottom: 8);

            Group {
              Anchor: (Height: 18, Bottom: 0);
              Label {
                Text: "Building";
                Style: (FontSize: 11, TextColor: #00AAAA, RenderBold: true);
              }
            }
            Group {
              Anchor: (Height: 12, Bottom: 4);
              Label {
                Text: "(children only apply when parent ON)";
                Style: (FontSize: 8, TextColor: #666666);
              }
            }

            // Flag 12: build_allowed (parent)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Label #Flag12Name {
                Text: "Build Allowed";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 110);
              }
              Label { FlexWeight: 1; }
              Label #Flag12Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag12Toggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 13: block_place (child, mixin: block_place)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Padding: (Left: 12, Right: 0, Top: 0, Bottom: 0);
              Label #Flag13Name {
                Text: "Block Place";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 98);
              }
              Label { FlexWeight: 1; }
              Label #Flag13Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag13Toggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 14: hammer_use (child, mixin: hammer)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Padding: (Left: 12, Right: 0, Top: 0, Bottom: 0);
              Label #Flag14Name {
                Text: "Hammer Use";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 98);
              }
              Label { FlexWeight: 1; }
              Label #Flag14Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag14Toggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 15: builder_tools_use (child, mixin: builder_tools)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Padding: (Left: 12, Right: 0, Top: 0, Bottom: 0);
              Label #Flag15Name {
                Text: "Builder Tools";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 98);
              }
              Label { FlexWeight: 1; }
              Label #Flag15Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag15Toggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }
