          // --- Interaction Box ---
          Group #InteractionBox {
            Background: (Color: #1a2a3a);
            Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
            LayoutMode: Top;
            Anchor: (Bottom: 8);

            Group {
              Anchor: (Height: 18, Bottom: 0);
              Label {
                Text: "Interaction";
                Style: (FontSize: 11, TextColor: #00AAAA, RenderBold: true);
              }
            }
            Group {
              Anchor: (Height: 12, Bottom: 4);
              Label {
                Text: "(children only apply when parent ON)";
                Style: (FontSize: 8, TextColor: #666666);
              }
            }

            // Flag 16: block_interact (parent)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Label #Flag16Name {
                Text: "Block Interact";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 110);
              }
              Label { FlexWeight: 1; }
              Label #Flag16Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag16Toggle {
                @Text = ""; @Checked = true;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Flag 17: door_use (child)
            Group {
              Anchor: (Height: 24);
              LayoutMode: Left;
              Padding: (Left: 12, Right: 0, Top: 0, Bottom: 0);
              Label #Flag17Name {
                Text: "Door Use";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 98);
              }
              Label { FlexWeight: 1; }
              Label #Flag17Default {
                Text: "(default)";
                Style: (FontSize: 9, TextColor: #555555, VerticalAlignment: Center);
                Anchor: (Width: 55);
              }
              $C.@CheckBoxWithLabel #Flag17Toggle {
