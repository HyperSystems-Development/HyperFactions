// Main Menu - Faction Section Content
// Displayed when player is in a faction

$C = "../../Common.ui";

Group {
  LayoutMode: Top;

  // Faction name display
  Group {
    Anchor: (Height: 30, Bottom: 8);
    LayoutMode: Left;

    Label {
      Text: "Your faction:";
      Style: (FontSize: 13, TextColor: #888888, VerticalAlignment: Center);
      Anchor: (Width: 100);
    }

    Label #FactionNameLabel {
      Text: "Faction Name";
      Style: (FontSize: 13, TextColor: #00FFFF, RenderBold: true, VerticalAlignment: Center);
      FlexWeight: 1;
    }
  }

  // Action buttons
  Group {
    Anchor: (Height: 40);
    LayoutMode: Left;

    TextButton #ViewFactionBtn {
      Text: "View";
      Anchor: (Height: 32, Width: 110);
      Style: $C.@SecondaryTextButtonStyle;
      TooltipText: "View your faction details and info";
      TextTooltipStyle: $C.@DefaultTextTooltipStyle;
    }

    Label { Anchor: (Width: 10); }

    TextButton #MembersBtn {
      Text: "Members";
      Anchor: (Height: 32, Width: 110);
      Style: $C.@SecondaryTextButtonStyle;
      TooltipText: "View and manage faction members";
      TextTooltipStyle: $C.@DefaultTextTooltipStyle;
    }

    Label { Anchor: (Width: 10); }

    TextButton #RelationsBtn {
      Text: "Relations";
      Anchor: (Height: 32, Width: 110);
      Style: $C.@SecondaryTextButtonStyle;
      TooltipText: "Manage diplomatic relations with other factions";
      TextTooltipStyle: $C.@DefaultTextTooltipStyle;
    }
  }
}
