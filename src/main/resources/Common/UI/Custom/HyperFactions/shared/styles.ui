// HyperFactions Shared Styles
// Only custom styles that have no native Hytale equivalent.
// All standard button styles now use native $C.@SecondaryTextButtonStyle,
// $C.@CancelTextButtonStyle, $C.@DefaultTextButtonStyle from Common.ui.

$C = "../../Common.ui";

// =============================================================================
// COLORS (reference only)
// =============================================================================
// Primary: #00FFFF (cyan)
// Secondary: #00AAAA (teal)
// Faction names: #00FFFF (cyan)
// Player names: #4a9eff (blue)
// Leader: #FFD700 (gold)
// Officer: #87CEEB (sky blue)
// Member: #AAAAAA (gray)
// Success: #44cc44
// Danger: #ff5555
// Warning: #FFAA00
// Ally: #00AAFF
// Enemy: #FF5555

// =============================================================================
// INVISIBLE BUTTON STYLE (transparent click overlays for chunk map & list rows)
// =============================================================================

@InvisibleLabelStyle = LabelStyle(
  FontSize: 13,
  TextColor: #bfcdd5,
  RenderBold: true,
  HorizontalAlignment: Center,
  VerticalAlignment: Center
);

@InvisibleButtonStyle = TextButtonStyle(
  Default: (Background: (Color: #00000000), LabelStyle: @InvisibleLabelStyle),
  Hovered: (Background: (Color: #00000000), LabelStyle: @InvisibleLabelStyle),
  Pressed: (Background: (Color: #00000000), LabelStyle: @InvisibleLabelStyle),
  Disabled: (Background: (Color: #00000000), LabelStyle: @InvisibleLabelStyle),
  Sounds: $C.@ButtonSounds,
);

// =============================================================================
// PLAYER MARKER STYLE (white bold text for map overlay)
// =============================================================================

@PlayerMarkerLabelStyle = LabelStyle(
  FontSize: 14,
  TextColor: #FFFFFF,
  RenderBold: true,
  HorizontalAlignment: Center,
  VerticalAlignment: Center
);

@PlayerMarkerButtonStyle = TextButtonStyle(
  Default: (Background: (Color: #00000000), LabelStyle: @PlayerMarkerLabelStyle),
  Hovered: (Background: (Color: #00000000), LabelStyle: @PlayerMarkerLabelStyle),
  Pressed: (Background: (Color: #00000000), LabelStyle: @PlayerMarkerLabelStyle),
  Disabled: (Background: (Color: #00000000), LabelStyle: @PlayerMarkerLabelStyle),
  Sounds: $C.@ButtonSounds,
);
