// Faction Info Page
// Card-based stat layout matching admin faction info style
// Used for /f info [faction] command (GUI mode)

$C = "../../Common.ui";
$S = "styles.ui";

$C.@PageOverlay {
  $C.@Container {
    Anchor: (Width: 560, Height: 520);

    #Title {
      $C.@Title {
        @Text = "Faction Info";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 20, Right: 20, Top: 12, Bottom: 12);

      // === Header Section ===
      Group #HeaderSection {
        Anchor: (Height: 55, Bottom: 8);
        LayoutMode: Top;

        // Faction name, tag, and status row
        Group {
          LayoutMode: Left;
          Anchor: (Height: 28);

          Label #FactionName {
            Text: "Faction Name";
            Style: (FontSize: 18, TextColor: #00FFFF, RenderBold: true, VerticalAlignment: Center);
          }

          Label #FactionTag {
            Text: "";
            Style: (FontSize: 14, TextColor: #FFD700, RenderBold: true, VerticalAlignment: Center);
            Anchor: (Left: 8);
          }

          Label { FlexWeight: 1; }

          Label #StatusIndicator {
            Text: "";
            Style: (FontSize: 12, TextColor: #44cc44, RenderBold: true, VerticalAlignment: Center);
          }
        }

        // Description
        Label #FactionDescription {
          Text: "No description set.";
          Style: (FontSize: 12, TextColor: #888888);
          Anchor: (Height: 20);
        }
      }

      // === Stats Row 1: Power, Claims, Members ===
      Group {
        Anchor: (Height: 75, Bottom: 8);
        LayoutMode: Left;

        // Power card
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Right: 4);

          Label {
            Text: "Power";
            Style: (FontSize: 9, TextColor: #666666);
            Anchor: (Height: 14);
          }
          Label #PowerValue {
            Text: "0.0 / 0.0";
            Style: (FontSize: 20, TextColor: #44CC44, RenderBold: true);
            FlexWeight: 1;
          }
          Label {
            Text: "current / max";
            Style: (FontSize: 9, TextColor: #444444);
            Anchor: (Height: 14);
          }
        }

        // Claims card
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4, Right: 4);

          Label {
            Text: "Claims";
            Style: (FontSize: 9, TextColor: #666666);
            Anchor: (Height: 14);
          }
          Label #ClaimsValue {
            Text: "0 / 0";
            Style: (FontSize: 20, TextColor: #FFAA00, RenderBold: true);
            FlexWeight: 1;
          }
          Label {
            Text: "claimed / max";
            Style: (FontSize: 9, TextColor: #444444);
            Anchor: (Height: 14);
          }
        }

        // Members card
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4);

          Label {
            Text: "Members";
            Style: (FontSize: 9, TextColor: #666666);
            Anchor: (Height: 14);
          }
          Label #MembersValue {
            Text: "0 / 0";
            Style: (FontSize: 20, TextColor: #00FFFF, RenderBold: true);
            FlexWeight: 1;
          }
          Label #RecruitmentValue {
            Text: "Invite Only";
            Style: (FontSize: 9, TextColor: #444444);
            Anchor: (Height: 14);
          }
        }
      }

      // === Stats Row 2: Relations, Status, Info ===
      Group {
        Anchor: (Height: 75, Bottom: 10);
        LayoutMode: Left;

        // Relations card (ally / enemy split)
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Right: 4);

          Label {
            Text: "Relations";
            Style: (FontSize: 9, TextColor: #666666);
            Anchor: (Height: 14);
          }
          Group {
            FlexWeight: 1;
            LayoutMode: Left;

            Label #AlliesValue {
              Text: "0";
              Style: (FontSize: 18, TextColor: #55FF55, RenderBold: true, VerticalAlignment: Center);
              FlexWeight: 1;
            }
            Label {
              Text: "/";
              Style: (FontSize: 14, TextColor: #444444, VerticalAlignment: Center);
              Anchor: (Width: 15);
            }
            Label #EnemiesValue {
              Text: "0";
              Style: (FontSize: 18, TextColor: #FF5555, RenderBold: true, VerticalAlignment: Center);
              FlexWeight: 1;
            }
          }
          Label {
            Text: "ally / enemy";
            Style: (FontSize: 9, TextColor: #444444);
            Anchor: (Height: 14);
          }
        }

        // Status card (raidable + founded)
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4, Right: 4);

          Label {
            Text: "Status";
            Style: (FontSize: 9, TextColor: #666666);
            Anchor: (Height: 14);
          }
          Label #RaidableValue {
            Text: "Protected";
            Style: (FontSize: 18, TextColor: #44cc44, RenderBold: true);
            FlexWeight: 1;
          }
          Label #FoundedValue {
            Text: "Unknown";
            Style: (FontSize: 9, TextColor: #444444);
            Anchor: (Height: 14);
          }
        }

        // Treasury card (hidden when economy disabled)
        Group #TreasuryCard {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4);
          Visible: false;

          Label {
            Text: "Treasury";
            Style: (FontSize: 9, TextColor: #666666);
            Anchor: (Height: 14);
          }
          Label #TreasuryValue {
            Text: "0";
            Style: (FontSize: 18, TextColor: #FFD700, RenderBold: true);
            FlexWeight: 1;
          }
          Label {
            Text: "faction balance";
            Style: (FontSize: 9, TextColor: #444444);
            Anchor: (Height: 14);
          }
        }
      }

      // Cyan divider
      Group {
        Anchor: (Height: 1, Bottom: 8);
        Background: (Color: #00AAAA);
      }

      // === Leadership Card ===
      Group #LeadershipSection {
        Anchor: (Height: 50, Bottom: 8);
        Background: (Color: #1a2a3a);
        Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
        LayoutMode: Left;

        Label {
          Text: "Leader:";
          Style: (FontSize: 12, TextColor: #FFD700, RenderBold: true, VerticalAlignment: Center);
          Anchor: (Width: 65);
        }

        Label #LeaderName {
          Text: "Unknown";
          Style: (FontSize: 12, TextColor: #FFFFFF, VerticalAlignment: Center);
        }

        Label { Anchor: (Width: 30); }

        Label {
          Text: "Officers:";
          Style: (FontSize: 12, TextColor: #87CEEB, RenderBold: true, VerticalAlignment: Center);
          Anchor: (Width: 70);
        }

        Label #OfficersValue {
          Text: "None";
          Style: (FontSize: 12, TextColor: #FFFFFF, VerticalAlignment: Center);
        }
      }

      // Spacer to push buttons to bottom
      Label { FlexWeight: 1; }

      // === Action Buttons ===
      Group #ActionButtons {
        Anchor: (Height: 35);
        LayoutMode: Left;

        TextButton #ViewMembersBtn {
          Text: "View Members";
          Anchor: (Height: 30, Width: 130);
          Style: $S.@ButtonStyle;
        }

        Label { Anchor: (Width: 10); }

        TextButton #ViewRelationsBtn {
          Text: "Relations";
          Anchor: (Height: 30, Width: 100);
          Style: $S.@ButtonStyle;
        }

        Label { FlexWeight: 1; }

        TextButton #BackBtn {
          Text: "Back";
          Anchor: (Height: 30, Width: 80);
          Style: $S.@ButtonStyle;
        }
      }
    }
  }
}

$C.@BackButton {}
