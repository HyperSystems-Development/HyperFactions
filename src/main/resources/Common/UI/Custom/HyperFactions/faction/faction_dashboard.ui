// Faction Dashboard Page
// Main dashboard for faction members with stats, quick actions, and activity feed

$C = "../../Common.ui";
$Nav = "../nav/nav_bar.ui";

$C.@PageOverlay {
  $Nav.@HyperFactionsNavBar #HyperFactionsNavBar {}

  $C.@DecoratedContainer {
    Anchor: (Width: 600, Height: 660);

    #Title {
      Group {
        $C.@Title {
          @Text = "Faction Dashboard";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 20, Right: 20, Top: 10, Bottom: 10);

      // Faction header (name, tag, description)
      Group #FactionHeader {
        Anchor: (Height: 50, Bottom: 10);
        LayoutMode: Top;

        Group {
          LayoutMode: Left;
          Anchor: (Height: 24);

          Label #FactionName {
            Text: "Faction Name";
            Style: (FontSize: 18, TextColor: #00FFFF, RenderBold: true, VerticalAlignment: Center);
          }

          Label #FactionTag {
            Text: "";
            Style: (FontSize: 14, TextColor: #FFD700, RenderBold: true, VerticalAlignment: Center);
            Anchor: (Left: 8);
          }
        }

        Label #FactionDescription {
          Text: "";
          Style: (FontSize: 12, TextColor: #888888);
          Anchor: (Height: 20);
        }
      }

      // Stats Grid - Row 1: Power, Claims, Members
      Group #StatsRow1 {
        Anchor: (Height: 80, Bottom: 10);
        LayoutMode: Left;

        // Power stat
        Group #PowerStat {
          TooltipText: "Faction power determines how much territory you can claim";
          TextTooltipStyle: $C.@DefaultTextTooltipStyle;
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 15, Right: 15, Top: 12, Bottom: 12);
          LayoutMode: Top;
          Anchor: (Right: 5);

          Label {
            Text: "Power";
            Style: (FontSize: 10, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 16);
          }
          Label #PowerValue {
            Text: "0 / 0";
            Style: (FontSize: 22, TextColor: #44CC44, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            FlexWeight: 1;
          }
          Label #PowerPercent {
            Text: "0%";
            Style: (FontSize: 10, TextColor: #888888, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }

        // Claims stat
        Group #ClaimsStat {
          TooltipText: "Territory chunks claimed by your faction";
          TextTooltipStyle: $C.@DefaultTextTooltipStyle;
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 15, Right: 15, Top: 12, Bottom: 12);
          LayoutMode: Top;
          Anchor: (Left: 5, Right: 5);

          Label {
            Text: "Claims";
            Style: (FontSize: 10, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 16);
          }
          Label #ClaimsValue {
            Text: "0 / 0";
            Style: (FontSize: 22, TextColor: #FFAA00, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            FlexWeight: 1;
          }
          Label #ClaimsAvailable {
            Text: "0 available";
            Style: (FontSize: 10, TextColor: #888888, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }

        // Members stat
        Group #MembersStat {
          TooltipText: "Total faction members and currently online count";
          TextTooltipStyle: $C.@DefaultTextTooltipStyle;
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 15, Right: 15, Top: 12, Bottom: 12);
          LayoutMode: Top;
          Anchor: (Left: 5);

          Label {
            Text: "Members";
            Style: (FontSize: 10, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 16);
          }
          Label #MembersValue {
            Text: "0";
            Style: (FontSize: 22, TextColor: #00FFFF, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            FlexWeight: 1;
          }
          Label #MembersOnline {
            Text: "0 online";
            Style: (FontSize: 10, TextColor: #888888, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }
      }

      // Stats Grid - Row 2: Relations, Status, Invites
      Group #StatsRow2 {
        Anchor: (Height: 80, Bottom: 15);
        LayoutMode: Left;

        // Relations stat
        Group #RelationsStat {
          TooltipText: "Allied and enemy faction count";
          TextTooltipStyle: $C.@DefaultTextTooltipStyle;
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 15, Right: 15, Top: 12, Bottom: 12);
          LayoutMode: Top;
          Anchor: (Right: 5);

          Label {
            Text: "Relations";
            Style: (FontSize: 10, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 16);
          }
          Group {
            FlexWeight: 1;
            LayoutMode: Left;

            Label #AllyCount {
              Text: "0";
              Style: (FontSize: 20, TextColor: #55FF55, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
              FlexWeight: 1;
            }
            Label {
              Text: "/";
              Style: (FontSize: 16, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
              Anchor: (Width: 15);
            }
            Label #EnemyCount {
              Text: "0";
              Style: (FontSize: 20, TextColor: #FF5555, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
              FlexWeight: 1;
            }
          }
          Label {
            Text: "ally / enemy";
            Style: (FontSize: 9, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }

        // Status stat
        Group #StatusStat {
          TooltipText: "Open factions accept join requests, Invite Only requires invitations";
          TextTooltipStyle: $C.@DefaultTextTooltipStyle;
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 15, Right: 15, Top: 12, Bottom: 12);
          LayoutMode: Top;
          Anchor: (Left: 5, Right: 5);

          Label {
            Text: "Status";
            Style: (FontSize: 10, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 16);
          }
          Label #StatusValue {
            Text: "Open";
            Style: (FontSize: 18, TextColor: #55FF55, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            FlexWeight: 1;
          }
          Label #StatusDesc {
            Text: "";
            Style: (FontSize: 9, TextColor: #888888, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }

        // Invites stat
        Group #InvitesStat {
          TooltipText: "Invitations sent to players and join requests received";
          TextTooltipStyle: $C.@DefaultTextTooltipStyle;
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 15, Right: 15, Top: 12, Bottom: 12);
          LayoutMode: Top;
          Anchor: (Left: 5);

          Label {
            Text: "Invites";
            Style: (FontSize: 10, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 16);
          }
          Group {
            FlexWeight: 1;
            LayoutMode: Left;

            Label #InvitesSent {
              Text: "0";
              Style: (FontSize: 20, TextColor: #00AAFF, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
              FlexWeight: 1;
            }
            Label {
              Text: "/";
              Style: (FontSize: 16, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
              Anchor: (Width: 15);
            }
            Label #InvitesReceived {
              Text: "0";
              Style: (FontSize: 20, TextColor: #FFAA00, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
              FlexWeight: 1;
            }
          }
          Label {
            Text: "sent / requests";
            Style: (FontSize: 9, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }
      }

      // Economy Stats Row (hidden when economy disabled)
      Group #EconomyRow {
        Anchor: (Height: 80, Bottom: 10);
        LayoutMode: Left;
        Visible: false;

        // Treasury Balance
        Group #TreasuryStat {
          TooltipText: "Faction treasury balance";
          TextTooltipStyle: $C.@DefaultTextTooltipStyle;
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 15, Right: 15, Top: 12, Bottom: 12);
          LayoutMode: Top;
          Anchor: (Right: 5);

          Label {
            Text: "Treasury";
            Style: (FontSize: 10, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 16);
          }
          Label #TreasuryBalance {
            Text: "0";
            Style: (FontSize: 22, TextColor: #FFD700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            FlexWeight: 1;
          }
          Label #TreasurySubtext {
            Text: "";
            Style: (FontSize: 9, TextColor: #888888, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }

        // Upkeep stat (hidden unless upkeep enabled)
        Group #UpkeepStat {
          TooltipText: "Cost per upkeep cycle to maintain claimed territory";
          TextTooltipStyle: $C.@DefaultTextTooltipStyle;
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 15, Right: 15, Top: 12, Bottom: 12);
          LayoutMode: Top;
          Anchor: (Left: 5, Right: 5);
          Visible: false;

          Label {
            Text: "Upkeep";
            Style: (FontSize: 10, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 16);
          }
          Label #UpkeepValue {
            Text: "0";
            Style: (FontSize: 22, TextColor: #FF5555, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            FlexWeight: 1;
          }
          Label #UpkeepSubtext {
            Text: "per cycle";
            Style: (FontSize: 9, TextColor: #888888, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }

        // Personal Wallet
        Group #WalletStat {
          TooltipText: "Your personal economy balance";
          TextTooltipStyle: $C.@DefaultTextTooltipStyle;
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 15, Right: 15, Top: 12, Bottom: 12);
          LayoutMode: Top;
          Anchor: (Left: 5);

          Label {
            Text: "Your Wallet";
            Style: (FontSize: 10, TextColor: #666666, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 16);
          }
          Label #WalletBalance {
            Text: "0";
            Style: (FontSize: 22, TextColor: #AAAAAA, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            FlexWeight: 1;
          }
          Label {
            Text: "personal balance";
            Style: (FontSize: 9, TextColor: #444444, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Height: 14);
          }
        }
      }

      // Quick actions section
      $C.@Subtitle { @Text = "Quick Actions"; Anchor: (Bottom: 8); }

      Group #QuickActionsRow {
        Anchor: (Height: 70, Bottom: 15);
        LayoutMode: Left;

        Group #HomeBtnContainer {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Right: 4);

          Label {
            Text: "Teleport";
            Style: (FontSize: 9, TextColor: #555555);
            Anchor: (Height: 14, Bottom: 4);
          }
        }

        Group #ClaimBtnContainer {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4, Right: 4);

          Label {
            Text: "Territory";
            Style: (FontSize: 9, TextColor: #555555);
            Anchor: (Height: 14, Bottom: 4);
          }
        }

        Group #ChatModeBtnContainer {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4, Right: 4);

          Label {
            Text: "Channel";
            Style: (FontSize: 9, TextColor: #555555);
            Anchor: (Height: 14, Bottom: 4);
          }
        }

        Group #LeaveBtnContainer {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4);

          Label {
            Text: "Membership";
            Style: (FontSize: 9, TextColor: #555555);
            Anchor: (Height: 14, Bottom: 4);
          }
        }
      }

      // Divider
      $C.@ContentSeparator { Anchor: (Bottom: 10); }

      // Activity feed section
      Group {
        Anchor: (Height: 25, Bottom: 5);
        LayoutMode: Left;

        $C.@Subtitle { @Text = "Recent Activity"; }

        Label { FlexWeight: 1; }

        TextButton #ViewLogsBtn {
          Text: "View All";
          Anchor: (Height: 22, Width: 70);
          Style: $C.@SecondaryTextButtonStyle;
          Disabled: true;
        }
      }

      // Activity entries container (scrollable)
      Group #ActivityFeed {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@TranslucentScrollbarStyle;
      }
    }
  }
}

// Native Hytale back button (bottom-left ESC)
$C.@BackButton {}
