// Player Info Page
// Card-based stat layout matching admin player info style
// Used for /f who [player] command (GUI mode) and member profile navigation

$C = "../../Common.ui";
$S = "../shared/styles.ui";

$C.@PageOverlay {
  $C.@Container {
    Anchor: (Width: 560, Height: 580);

    #Title {
      $C.@Title #PageTitle {
        @Text = "Player Info";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 20, Right: 20, Top: 12, Bottom: 12);

      // === Header Section ===
      Group {
        Anchor: (Height: 50, Bottom: 8);
        LayoutMode: Top;

        // Player name and online status row
        Group {
          LayoutMode: Left;
          Anchor: (Height: 28);

          Label #PlayerName {
            Text: "PlayerName";
            Style: (FontSize: 18, TextColor: #4a9eff, RenderBold: true, VerticalAlignment: Center);
          }

          Label { Anchor: (Width: 10); }

          Label #OnlineIndicator {
            Text: "Offline";
            Style: (FontSize: 12, TextColor: #888888, RenderBold: true, VerticalAlignment: Center);
          }
        }

        // First Joined / Last Online subtitle
        Group {
          LayoutMode: Left;
          Anchor: (Height: 18);

          Label #FirstJoinedLabel {
            Text: "First joined:";
            Style: (FontSize: 10, TextColor: #666666, VerticalAlignment: Center);
            Anchor: (Width: 75);
          }
          Label #FirstJoinedValue {
            Text: "";
            Style: (FontSize: 10, TextColor: #AAAAAA, VerticalAlignment: Center);
            Anchor: (Width: 130);
          }

          Label #LastOnlineLabel {
            Text: "Last online:";
            Style: (FontSize: 10, TextColor: #666666, VerticalAlignment: Center);
            Anchor: (Width: 70);
          }
          Label #LastOnlineValue {
            Text: "";
            Style: (FontSize: 10, TextColor: #AAAAAA, VerticalAlignment: Center);
          }
        }
      }

      // === Faction Card ===
      Group #FactionSection {
        Anchor: (Height: 80, Bottom: 8);
        Background: (Color: #1a2a3a);
        Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
        LayoutMode: Top;

        // Faction Name row
        Group #FactionNameRow {
          Anchor: (Height: 22);
          LayoutMode: Left;

          Label #FactionLabel {
            Text: "Faction:";
            Style: (FontSize: 12, TextColor: #666666, VerticalAlignment: Center);
            Anchor: (Width: 60);
          }

          Label #FactionNameValue {
            Text: "None";
            Style: (FontSize: 12, TextColor: #00FFFF, RenderBold: true, VerticalAlignment: Center);
          }
        }

        // Role row
        Group #FactionRoleRow {
          Anchor: (Height: 22);
          LayoutMode: Left;

          Label #RoleLabel {
            Text: "Role:";
            Style: (FontSize: 12, TextColor: #666666, VerticalAlignment: Center);
            Anchor: (Width: 60);
          }

          Label #FactionRoleValue {
            Text: "";
            Style: (FontSize: 12, TextColor: #FFFFFF, VerticalAlignment: Center);
          }
        }

        // Joined / View button row
        Group #FactionJoinedRow {
          Anchor: (Height: 26);
          LayoutMode: Left;

          Label #JoinedLabel {
            Text: "Joined:";
            Style: (FontSize: 12, TextColor: #666666, VerticalAlignment: Center);
            Anchor: (Width: 60);
          }

          Label #FactionJoinedValue {
            Text: "";
            Style: (FontSize: 12, TextColor: #AAAAAA, VerticalAlignment: Center);
            Anchor: (Width: 140);
          }

          Label { FlexWeight: 1; }

          TextButton #ViewFactionBtn {
            Text: "View Faction";
            Anchor: (Height: 24, Width: 110);
            Style: $S.@CyanButtonStyle;
          }
        }

        // No faction label (hidden when in a faction)
        Label #NoFactionLabel {
          Text: "Not in a faction";
          Style: (FontSize: 12, TextColor: #555555);
          Anchor: (Height: 22);
        }
      }

      // === Stats Row: Power, Combat, KDR ===
      Group {
        Anchor: (Height: 75, Bottom: 4);
        LayoutMode: Left;

        // Power card
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Right: 4);

          Label #PowerHeader {
            Text: "Power";
            Style: (FontSize: 9, TextColor: #666666);
            Anchor: (Height: 14);
          }
          Label #PowerValue {
            Text: "0.0 / 0.0";
            Style: (FontSize: 20, TextColor: #FFFFFF, RenderBold: true);
            FlexWeight: 1;
          }
          Label #PowerSubtitle {
            Text: "current / max";
            Style: (FontSize: 9, TextColor: #444444);
            Anchor: (Height: 14);
          }
        }

        // Combat card
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4, Right: 4);

          Label #CombatHeader {
            Text: "Combat";
            Style: (FontSize: 9, TextColor: #666666);
            Anchor: (Height: 14);
          }
          Group {
            FlexWeight: 1;
            LayoutMode: Left;

            Label #KillsValue {
              Text: "0";
              Style: (FontSize: 16, TextColor: #55FF55, RenderBold: true, VerticalAlignment: Center);
              FlexWeight: 1;
            }
            Label {
              Text: "/";
              Style: (FontSize: 14, TextColor: #444444, VerticalAlignment: Center);
              Anchor: (Width: 12);
            }
            Label #DeathsValue {
              Text: "0";
              Style: (FontSize: 16, TextColor: #FF5555, RenderBold: true, VerticalAlignment: Center);
              FlexWeight: 1;
            }
          }
          Label #CombatSubtitle {
            Text: "kills / deaths";
            Style: (FontSize: 9, TextColor: #444444);
            Anchor: (Height: 14);
          }
        }

        // KDR card
        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4);

          Label #KDRHeader {
            Text: "K/D Ratio";
            Style: (FontSize: 9, TextColor: #666666);
            Anchor: (Height: 14);
          }
          Label #KDRValue {
            Text: "0.00";
            Style: (FontSize: 20, TextColor: #FFFFFF, RenderBold: true);
            FlexWeight: 1;
          }
          Label {
            Text: "";
            Anchor: (Height: 14);
          }
        }
      }

      // Power bar
      ProgressBar #PowerBar {
        Anchor: (Height: 6, Bottom: 10);
        Value: 0.5;
        Bar: (Color: #55FF55);
        Background: (Color: #0d1520);
      }

      // Cyan divider
      Group {
        Anchor: (Height: 1, Bottom: 8);
        Background: (Color: #00AAAA);
      }

      // === Membership History Section ===
      Group {
        Anchor: (Height: 20, Bottom: 4);
        LayoutMode: Left;

        Label #MembershipHistoryLabel {
          Text: "Membership History";
          Style: (FontSize: 11, TextColor: #666666, RenderBold: true);
        }

        Label { Anchor: (Width: 8); }

        Label #HistoryCount {
          Text: "";
          Style: (FontSize: 10, TextColor: #555555);
        }
      }

      // History list container (dynamic entries appended here, scrollable)
      Group #HistoryList {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
      }

      // Spacer
      Group { Anchor: (Height: 8); }

      // === Back Button ===
      Group {
        Anchor: (Height: 35);
        LayoutMode: Left;

        Label { FlexWeight: 1; }

        TextButton #BackBtn {
          Text: "Back";
          Anchor: (Height: 30, Width: 80);
          Style: $S.@ButtonStyle;
        }
      }
    }
  }
}

$C.@BackButton {}
