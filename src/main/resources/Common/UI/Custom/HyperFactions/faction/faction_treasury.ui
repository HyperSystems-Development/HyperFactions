// Faction Treasury Page v2
// Stat cards, upkeep section, quick action buttons, transaction log, settings button

$C = "../../Common.ui";
$S = "../shared/styles.ui";
$Nav = "../nav/nav_bar.ui";

$C.@PageOverlay {
  $Nav.@HyperFactionsNavBar #HyperFactionsNavBar {}

  $C.@DecoratedContainer {
    Anchor: (Width: 900, Height: 680);

    #Title {
      Group {
        $C.@Title {
          @Text = "Faction Treasury";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 20, Right: 20, Top: 20, Bottom: 10);

      // === A. Stats Row ===
      Group #StatsRow {
        Anchor: (Height: 80, Bottom: 8);
        LayoutMode: Left;

        // Balance card
        Group #BalanceStat {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 15, Right: 15, Top: 12, Bottom: 12);
          LayoutMode: Top;
          Anchor: (Right: 5);

          Label {
            Text: "Balance";
            Style: (FontSize: 10, TextColor: #666666);
            Anchor: (Height: 16);
          }
          Label #BalanceValue {
            Text: "0.00";
            Style: (FontSize: 22, TextColor: #FFD700, RenderBold: true);
            FlexWeight: 1;
          }
          Label #WalletBalance {
            Text: "Your wallet: 0.00";
            Style: (FontSize: 10, TextColor: #888888);
            Anchor: (Height: 14);
          }
        }

        // Income (24h) card
        Group #IncomeStat {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 15, Right: 15, Top: 12, Bottom: 12);
          LayoutMode: Top;
          Anchor: (Left: 5, Right: 5);

          Label {
            Text: "Income (24h)";
            Style: (FontSize: 10, TextColor: #666666);
            Anchor: (Height: 16);
          }
          Label #IncomeValue {
            Text: "0.00";
            Style: (FontSize: 22, TextColor: #44CC44, RenderBold: true);
            FlexWeight: 1;
          }
          Label {
            Text: "deposits, transfers in";
            Style: (FontSize: 10, TextColor: #888888);
            Anchor: (Height: 14);
          }
        }

        // Expenses (24h) card
        Group #ExpensesStat {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 15, Right: 15, Top: 12, Bottom: 12);
          LayoutMode: Top;
          Anchor: (Left: 5);

          Label {
            Text: "Expenses (24h)";
            Style: (FontSize: 10, TextColor: #666666);
            Anchor: (Height: 16);
          }
          Label #ExpensesValue {
            Text: "0.00";
            Style: (FontSize: 22, TextColor: #FF5555, RenderBold: true);
            FlexWeight: 1;
          }
          Label {
            Text: "withdrawals, transfers out";
            Style: (FontSize: 10, TextColor: #888888);
            Anchor: (Height: 14);
          }
        }
      }

      // === C. Upkeep Section (hidden by default) ===
      Group #UpkeepSection {
        Visible: false;
        Anchor: (Bottom: 10);
        Background: (Color: #1a2a3a);
        Padding: (Left: 15, Right: 15, Top: 10, Bottom: 10);
        LayoutMode: Top;

        // Header row
        Group {
          LayoutMode: Left;
          Anchor: (Height: 18);

          Label {
            Text: "MAINTENANCE";
            Style: (FontSize: 11, TextColor: #888888, RenderBold: true);
          }
          Label { FlexWeight: 1; }
          Label #UpkeepCost {
            Text: "Cost: --";
            Style: (FontSize: 10, TextColor: #AAAAAA);
          }
        }

        // Progress bar row
        Group {
          LayoutMode: Left;
          Anchor: (Height: 22, Top: 4);

          ProgressBar #UpkeepBar {
            FlexWeight: 1;
            Anchor: (Height: 16);
            Bar: (Color: #55FF55);
            Background: (Color: #333333);
          }
          Label { Anchor: (Width: 8); }
          Label #UpkeepTimer {
            Text: "--";
            Style: (FontSize: 10, TextColor: #AAAAAA);
          }
        }

        // Detail row (free + billable chunks)
        Label #UpkeepDetail {
          Text: "";
          Style: (FontSize: 9, TextColor: #888888);
          Anchor: (Height: 14, Top: 2);
        }

        // Auto-pay row
        Group {
          LayoutMode: Left;
          Anchor: (Height: 16, Top: 2);

          Label #AutoPayStatus {
            Text: "Auto-pay: ON";
            Style: (FontSize: 10, TextColor: #55FF55);
          }
        }

        // Cost projections row
        Group #ProjectionsRow {
          Visible: false;
          Anchor: (Top: 6);
          Background: (Color: #111a28);
          Padding: (Left: 10, Right: 10, Top: 6, Bottom: 6);
          LayoutMode: Top;

          // Runway
          Group {
            LayoutMode: Left;
            Anchor: (Height: 16, Bottom: 4);

            Label {
              Text: "Runway:";
              Style: (FontSize: 10, TextColor: #888888);
              Anchor: (Width: 55);
            }
            Label #RunwayValue {
              Text: "--";
              Style: (FontSize: 10, TextColor: #55FF55, RenderBold: true);
            }
          }

          // Cost projections
          Group {
            LayoutMode: Left;
            Anchor: (Height: 16);

            Label {
              Text: "7d:";
              Style: (FontSize: 9, TextColor: #666666);
              Anchor: (Width: 20);
            }
            Label #Cost7d {
              Text: "--";
              Style: (FontSize: 9, TextColor: #AAAAAA);
              Anchor: (Width: 70);
            }
            Label {
              Text: "14d:";
              Style: (FontSize: 9, TextColor: #666666);
              Anchor: (Width: 25);
            }
            Label #Cost14d {
              Text: "--";
              Style: (FontSize: 9, TextColor: #AAAAAA);
              Anchor: (Width: 70);
            }
            Label {
              Text: "30d:";
              Style: (FontSize: 9, TextColor: #666666);
              Anchor: (Width: 25);
            }
            Label #Cost30d {
              Text: "--";
              Style: (FontSize: 9, TextColor: #AAAAAA);
            }
          }
        }

        // Grace period warning banner
        Group #GraceWarning {
          Visible: false;
          Anchor: (Top: 6);
          Background: (Color: #3a1a1a);
          Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
          LayoutMode: Top;

          // Info row: timer left, missed count right
          Group {
            LayoutMode: Left;
            Anchor: (Height: 16);

            Label #GraceTimer {
              Text: "Grace expires in: --";
              Style: (FontSize: 10, TextColor: #FF5555, RenderBold: true);
              FlexWeight: 1;
            }
            Label #MissedCount {
              Text: "Missed payments: 0";
              Style: (FontSize: 10, TextColor: #FFAA00);
            }
          }

          // Pay Now action (hidden by default, shown when can afford)
          Group #PayNowRow {
            Visible: false;
            LayoutMode: Left;
            Anchor: (Height: 30, Top: 8);

            Label #PayNowCost {
              Text: "";
              Style: (FontSize: 10, TextColor: #AAAAAA, VerticalAlignment: Center);
              FlexWeight: 1;
            }
            TextButton #PayNowBtn {
              Text: "Pay Now";
              Anchor: (Width: 120, Height: 28);
              Style: $S.@FlatRedButtonStyle;
            }
          }
        }
      }

      // === D. Quick Actions ===
      Group #QuickActions {
        Anchor: (Height: 64, Bottom: 10);
        LayoutMode: Left;

        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Right: 4);

          Label {
            Text: "Add funds";
            Style: (FontSize: 9, TextColor: #555555);
            Anchor: (Height: 14, Bottom: 4);
          }
          TextButton #DepositBtn {
            Text: "Deposit";
            Anchor: (Height: 30);
            Style: $S.@GreenButtonStyle;
          }
        }

        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4, Right: 4);

          Label {
            Text: "Take funds";
            Style: (FontSize: 9, TextColor: #555555);
            Anchor: (Height: 14, Bottom: 4);
          }
          TextButton #WithdrawBtn {
            Text: "Withdraw";
            Anchor: (Height: 30);
            Style: $S.@ButtonStyle;
          }
        }

        Group {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4, Right: 4);

          Label {
            Text: "Send to faction";
            Style: (FontSize: 9, TextColor: #555555);
            Anchor: (Height: 14, Bottom: 4);
          }
          TextButton #TransferBtn {
            Text: "Transfer";
            Anchor: (Height: 30);
            Style: $S.@CyanButtonStyle;
          }
        }

        // Settings (leader-only, hidden by default)
        Group #SettingsBox {
          FlexWeight: 1;
          Background: (Color: #1a2a3a);
          Padding: (Left: 8, Right: 8, Top: 8, Bottom: 8);
          LayoutMode: Top;
          Anchor: (Left: 4);
          Visible: false;

          Label {
            Text: "Treasury config";
            Style: (FontSize: 9, TextColor: #555555);
            Anchor: (Height: 14, Bottom: 4);
          }
          TextButton #SettingsBtn {
            Text: "Settings";
            Anchor: (Height: 30);
            Style: $S.@ButtonStyle;
          }
        }
      }

      // === Divider ===
      Group {
        Anchor: (Height: 1, Bottom: 8);
        Background: (Color: #00AAAA);
      }

      // === E. Transaction Log ===
      Group {
        Anchor: (Height: 22);
        LayoutMode: Left;

        Label {
          Text: "Recent Transactions";
          Style: (FontSize: 11, TextColor: #888888, RenderBold: true);
          FlexWeight: 1;
        }

        Label #NoTransactions {
          Text: "No transactions yet";
          Style: (FontSize: 10, TextColor: #555555);
          Visible: true;
        }
      }

      // Column headers
      Group #ColumnHeaders {
        Anchor: (Height: 20);
        LayoutMode: Left;

        Label {
          Text: "Date";
          Style: (FontSize: 10, TextColor: #555555);
          Anchor: (Width: 100);
        }
        Label {
          Text: "Type";
          Style: (FontSize: 10, TextColor: #555555);
          Anchor: (Width: 100);
        }
        Label {
          Text: "By";
          Style: (FontSize: 10, TextColor: #555555);
          Anchor: (Width: 90);
        }
        Label {
          Text: "Amount";
          Style: (FontSize: 10, TextColor: #555555);
          Anchor: (Width: 100);
        }
        Label {
          Text: "Details";
          Style: (FontSize: 10, TextColor: #555555);
          FlexWeight: 1;
        }
      }

      // Scrollable transaction list
      Group #TransactionLog {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Background: (Color: #0d1520);

        Group #TransactionList {
          LayoutMode: Top;
        }
      }

    }
  }
}

$C.@BackButton {}
