// Faction Leaderboard Page
// Ranked list of factions by power, territory, balance, or members

$C = "../../Common.ui";
$S = "../shared/styles.ui";
$Nav = "../nav/nav_bar.ui";

$C.@PageOverlay {
  $Nav.@HyperFactionsNavBar #HyperFactionsNavBar {}

  $C.@Container {
    Anchor: (Width: 700, Height: 500);

    #Title {
      $C.@Title {
        @Text = "Faction Leaderboard";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 15, Right: 15, Top: 10, Bottom: 10);

      // Header row with count and sort
      Group {
        Anchor: (Height: 35, Bottom: 8);
        LayoutMode: Left;

        Label #FactionCount {
          Text: "0 factions";
          Style: (FontSize: 13, TextColor: #888888, VerticalAlignment: Center);
          Anchor: (Width: 120);
        }

        Group { FlexWeight: 1; }

        Label {
          Text: "Rank by:";
          Style: (FontSize: 11, TextColor: #888888, VerticalAlignment: Center);
          Anchor: (Width: 55);
        }
        DropdownBox #SortDropdown {
          Style: $C.@DefaultDropdownBoxStyle;
          Anchor: (Height: 28, Width: 150);
        }
      }

      // Column headers
      Group {
        Anchor: (Height: 24, Bottom: 4);
        LayoutMode: Left;
        Padding: (Left: 12, Right: 12);

        Label {
          Text: "#";
          Style: (FontSize: 10, TextColor: #666666, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: Center);
          Anchor: (Width: 35);
        }
        Label {
          Text: "Faction";
          Style: (FontSize: 10, TextColor: #666666, RenderBold: true, VerticalAlignment: Center);
          Anchor: (Width: 200);
        }
        Label #StatHeader {
          Text: "Power";
          Style: (FontSize: 10, TextColor: #666666, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: Center);
          Anchor: (Width: 100);
        }
        Label {
          Text: "Claims";
          Style: (FontSize: 10, TextColor: #666666, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: Center);
          Anchor: (Width: 70);
        }
        Label {
          Text: "Members";
          Style: (FontSize: 10, TextColor: #666666, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: Center);
          Anchor: (Width: 70);
        }
      }

      // Divider
      Group {
        Anchor: (Height: 1, Bottom: 4);
        Background: (Color: #FFD700);
      }

      // Scrollable leaderboard list
      Group #LeaderboardListContainer {
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        FlexWeight: 1;

        Group #LeaderboardList {
          LayoutMode: Top;
        }
      }

      // Divider
      Group {
        Anchor: (Height: 1, Top: 8, Bottom: 8);
        Background: (Color: #FFD700);
      }

      // Pagination
      Group #Pagination {
        Anchor: (Height: 35);
        LayoutMode: Left;

        TextButton #PrevBtn {
          Text: "< Prev";
          Anchor: (Height: 26, Width: 80);
          Style: $S.@ButtonStyle;
        }

        Label { FlexWeight: 1; }

        Label #PageInfo {
          Text: "1/1";
          Style: (FontSize: 14, TextColor: #888888, HorizontalAlignment: Center, VerticalAlignment: Center);
          Anchor: (Width: 60);
        }

        Label { FlexWeight: 1; }

        TextButton #NextBtn {
          Text: "Next >";
          Anchor: (Height: 26, Width: 80);
          Style: $S.@ButtonStyle;
        }
      }
    }
  }
}

$C.@BackButton {}
