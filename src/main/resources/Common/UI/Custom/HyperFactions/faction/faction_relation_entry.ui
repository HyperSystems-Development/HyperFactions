// Faction Relation Entry - Expandable
// Collapsible row with header stats and inline quick actions
// Used for both Relations tab (allies/enemies) and Pending tab (incoming/outgoing)
$C = "../../Common.ui";
$S = "../shared/styles.ui";

Group {
  LayoutMode: Top;
  Anchor: (Bottom: 4);

  // Header wrapper - contains content and clickable overlay
  Group #HeaderWrapper {
    Anchor: (Height: 44);

    // Header content (visual layout)
    Group #HeaderContent {
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Background: (Color: #1a2a3a);
      Padding: (Left: 0, Right: 12, Top: 6, Bottom: 6);
      LayoutMode: Left;

      // Relation badge (colored bar)
      Group #RelationBadge {
        Anchor: (Width: 4, Top: 0, Bottom: 0);
        Background: (Color: #00AAFF);
      }

      // Faction name and leader
      Group {
        Anchor: (Width: 180);
        Padding: (Left: 10);
        LayoutMode: Top;

        Label #FactionName {
          Text: "Faction";
          Style: (FontSize: 13, TextColor: #00FFFF, RenderBold: true, VerticalAlignment: Center);
          Anchor: (Height: 18);
        }
        Label #LeaderName {
          Text: "Leader: Unknown";
          Style: (FontSize: 10, TextColor: #FFD700, VerticalAlignment: Center);
          Anchor: (Height: 14);
        }
      }

      // Relation type label
      Group {
        Anchor: (Width: 75);
        LayoutMode: Left;

        Label #RelationType {
          Text: "Ally";
          Style: (FontSize: 10, TextColor: #00AAFF, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: Center);
        }
      }

      // Member count
      Group {
        Anchor: (Width: 65);
        LayoutMode: Top;

        Label #MemberCount {
          Text: "0";
          Style: (FontSize: 12, TextColor: #888888, VerticalAlignment: Center, HorizontalAlignment: Center);
          Anchor: (Height: 18);
        }
        Label {
          Text: "members";
          Style: (FontSize: 9, TextColor: #666666, VerticalAlignment: Center, HorizontalAlignment: Center);
          Anchor: (Height: 14);
        }
      }

      // Power display
      Group {
        Anchor: (Width: 80);
        LayoutMode: Top;

        Label #PowerDisplay {
          Text: "0/0";
          Style: (FontSize: 12, TextColor: #44CC44, VerticalAlignment: Center, HorizontalAlignment: Center);
          Anchor: (Height: 18);
        }
        Label {
          Text: "power";
          Style: (FontSize: 9, TextColor: #666666, VerticalAlignment: Center, HorizontalAlignment: Center);
          Anchor: (Height: 14);
        }
      }

      Group { FlexWeight: 1; }

      // Expand indicators
      Label #ExpandIcon {
        Text: ">";
        Style: (FontSize: 14, TextColor: #666666, VerticalAlignment: Center, HorizontalAlignment: Center);
        Anchor: (Width: 20);
      }
      Label #CollapseIcon {
        Text: "v";
        Style: (FontSize: 14, TextColor: #00AAAA, VerticalAlignment: Center, HorizontalAlignment: Center);
        Anchor: (Width: 20);
      }
    }

    // Clickable overlay button
    TextButton #Header {
      Text: "";
      Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
      Style: $S.@InvisibleButtonStyle;
    }
  }

  // Expanded content
  Group #ExtendedInfo {
    LayoutMode: Top;
    Background: (Color: #0d1520);
    Padding: (Left: 25, Right: 12, Top: 8, Bottom: 10);

    // Stats row (for Relations tab)
    Group #StatsRow {
      LayoutMode: Left;
      Anchor: (Height: 20, Bottom: 4);

      Label {
        Text: "Since:";
        Style: (FontSize: 10, TextColor: #666666, VerticalAlignment: Center);
        Anchor: (Width: 50);
      }
      Label #SinceValue {
        Text: "Unknown";
        Style: (FontSize: 10, TextColor: #888888, VerticalAlignment: Center);
        Anchor: (Width: 100);
      }

      Label {
        Text: "Claims:";
        Style: (FontSize: 10, TextColor: #666666, VerticalAlignment: Center);
        Anchor: (Width: 50);
      }
      Label #ClaimsValue {
        Text: "0";
        Style: (FontSize: 10, TextColor: #FFAA00, VerticalAlignment: Center);
        FlexWeight: 1;
      }
    }

    // Pending info row (for Pending tab)
    Group #PendingRow {
      LayoutMode: Left;
      Anchor: (Height: 20, Bottom: 4);

      Label {
        Text: "Direction:";
        Style: (FontSize: 10, TextColor: #666666, VerticalAlignment: Center);
        Anchor: (Width: 65);
      }
      Label #DirectionValue {
        Text: "Incoming";
        Style: (FontSize: 10, TextColor: #888888, VerticalAlignment: Center);
        FlexWeight: 1;
      }
    }

    // Action buttons
    Group #ActionButtons {
      LayoutMode: Left;
      Anchor: (Height: 32);

      // View button (always available)
      TextButton #ViewBtn {
        Text: "View";
        Anchor: (Height: 28, Width: 65);
        Style: $S.@ButtonStyle;
      }

      Group #ViewSpacer { Anchor: (Width: 8); }

      // For allies/enemies: change relation
      TextButton #NeutralBtn {
        Text: "Neutral";
        Anchor: (Height: 28, Width: 80);
        Style: $S.@ButtonStyle;
      }

      Group #NeutralSpacer { Anchor: (Width: 8); }

      TextButton #EnemyBtn {
        Text: "Enemy";
        Anchor: (Height: 28, Width: 70);
        Style: $S.@RedButtonStyle;
      }

      TextButton #AllyBtn {
        Text: "Ally";
        Anchor: (Height: 28, Width: 60);
        Style: $S.@ButtonStyle;
      }

      // For pending requests
      TextButton #AcceptBtn {
        Text: "Accept";
        Anchor: (Height: 28, Width: 75);
        Style: $S.@ButtonStyle;
      }

      Group #AcceptSpacer { Anchor: (Width: 8); }

      TextButton #DeclineBtn {
        Text: "Decline";
        Anchor: (Height: 28, Width: 80);
        Style: $S.@RedButtonStyle;
      }

      TextButton #CancelBtn {
        Text: "Cancel";
        Anchor: (Height: 28, Width: 75);
        Style: $S.@RedButtonStyle;
      }

      Group { FlexWeight: 1; }
    }
  }
}
