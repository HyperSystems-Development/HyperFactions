// Create Faction - Three-column layout
// Left: preview, basic info, details
// Middle: building permissions, interaction permissions
// Right: faction color, mob spawning, combat, create button

$C = "../../Common.ui";
$S = "../shared/styles.ui";
$Nav = "../nav/nav_bar.ui";

$C.@PageOverlay {
  $Nav.@HyperFactionsNavBar #HyperFactionsNavBar {}

  $C.@DecoratedContainer {
    Anchor: (Width: 1000, Height: 700);

    #Title {
      $C.@Title {
        @Text = "Create Your Faction";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Left: 15, Right: 15, Top: 10, Bottom: 10);

      // === Three Column Layout ===
      Group #ThreeColumnContainer {
        LayoutMode: Left;
        FlexWeight: 1;

        // === LEFT COLUMN ===
        Group #LeftColumn {
          Anchor: (Width: 280);
          LayoutMode: Top;
          Padding: (Left: 0, Right: 8, Top: 0, Bottom: 0);

          // --- PREVIEW ---
          Label {
            Text: "Preview";
            Style: (FontSize: 11, TextColor: #888888, RenderBold: true);
            Anchor: (Height: 18, Bottom: 4);
          }
          Group {
            Anchor: (Height: 1, Bottom: 8);
            Background: (Color: #334455);
          }

          Group {
            Background: (Color: #1a2a3a);
            Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
            Anchor: (Height: 56, Bottom: 12);
            LayoutMode: Top;

            Group {
              LayoutMode: Left;
              Anchor: (Height: 20);

              Label {
                Text: "Name: ";
                Style: (FontSize: 13, TextColor: #AAAAAA);
              }
              Label #PreviewName {
                Text: "Your Faction Name";
                Style: (FontSize: 13, TextColor: #55FFFF, RenderBold: true);
              }
            }

            Label #PreviewLeader {
              Text: "Leader: PlayerName";
              Style: (FontSize: 12, TextColor: #888888);
              Anchor: (Height: 18);
            }
          }

          // --- BASIC INFO ---
          Label {
            Text: "Basic Info";
            Style: (FontSize: 11, TextColor: #888888, RenderBold: true);
            Anchor: (Height: 18, Bottom: 4);
          }
          Group {
            Anchor: (Height: 1, Bottom: 8);
            Background: (Color: #334455);
          }

          Group {
            Background: (Color: #1a2a3a);
            Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
            Anchor: (Height: 130, Bottom: 12);
            LayoutMode: Top;

            Label {
              Text: "Faction Name *";
              Style: (FontSize: 11, TextColor: #AAAAAA);
              Anchor: (Height: 16);
            }
            $C.@TextField #NameInput {
              Anchor: (Height: 32, Bottom: 6);
            }

            Label {
              Text: "TAG (2-4 chars, auto if empty)";
              Style: (FontSize: 11, TextColor: #AAAAAA);
              Anchor: (Height: 16);
            }
            Group {
              LayoutMode: Left;
              Anchor: (Height: 32);

              $C.@TextField #TagInput {
                Anchor: (Height: 32, Width: 100);
              }
            }
          }

          // --- DETAILS ---
          Label {
            Text: "Details";
            Style: (FontSize: 11, TextColor: #888888, RenderBold: true);
            Anchor: (Height: 18, Bottom: 4);
          }
          Group {
            Anchor: (Height: 1, Bottom: 8);
            Background: (Color: #334455);
          }

          Group {
            Background: (Color: #1a2a3a);
            Padding: (Left: 12, Right: 12, Top: 10, Bottom: 10);
            LayoutMode: Top;

            Label {
              Text: "Description (Optional)";
              Style: (FontSize: 11, TextColor: #AAAAAA);
              Anchor: (Height: 16);
            }
            $C.@TextField #DescInput {
              Anchor: (Height: 50, Bottom: 6);
            }

            Label {
              Text: "Recruitment";
              Style: (FontSize: 11, TextColor: #AAAAAA);
              Anchor: (Height: 16, Bottom: 4);
            }
            Group {
              LayoutMode: Left;
              Anchor: (Height: 32);

              DropdownBox #RecruitmentDropdown {
                Style: $C.@DefaultDropdownBoxStyle;
                Anchor: (Height: 28, Width: 180);
              }
            }
          }
        }

        // Vertical divider 1
        Group {
          Anchor: (Width: 1);
          Background: (Color: #334455);
        }

        // === MIDDLE COLUMN - Territory Permissions (Rotated Grid) ===
        Group #MiddleColumn {
          Anchor: (Width: 370);
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Padding: (Left: 8, Right: 8, Top: 0, Bottom: 0);

          // Lock hint
          Group {
            Anchor: (Height: 22, Bottom: 6);
            Background: (Color: #1a1a2a);
            Padding: (Left: 8, Right: 8, Top: 0, Bottom: 0);
            LayoutMode: Left;

            Label {
              Text: "Some options may be locked by the server and won't accept changes.";
              Style: (FontSize: 9, TextColor: #555577, VerticalAlignment: Center);
              FlexWeight: 1;
            }
          }

          // ---- TERRITORY PERMISSIONS ----
          Label {
            Text: "Territory Permissions";
            Style: (FontSize: 11, TextColor: #888888, RenderBold: true);
            Anchor: (Height: 18, Bottom: 4);
          }
          Group {
            Anchor: (Height: 1, Bottom: 8);
            Background: (Color: #334455);
          }

          Group #PermissionsBox {
            Background: (Color: #1a2a3a);
            Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8);
            LayoutMode: Top;

            // Column header row: [label spacer] [Out] [Ally] [Mem] [Off]
            Group {
              LayoutMode: Left;
              Anchor: (Height: 20, Bottom: 4);
              Padding: (Left: 6, Right: 6);

              Label { Anchor: (Width: 122); }
              Label {
                Text: "Out";
                Style: (FontSize: 9, TextColor: #AAAAAA, RenderBold: true);
                Anchor: (Width: 52);
              }
              Label {
                Text: "Ally";
                Style: (FontSize: 9, TextColor: #55FF55, RenderBold: true);
                Anchor: (Width: 52);
              }
              Label {
                Text: "Mem";
                Style: (FontSize: 9, TextColor: #00FFFF, RenderBold: true);
                Anchor: (Width: 52);
              }
              Label {
                Text: "Off";
                Style: (FontSize: 9, TextColor: #FFD700, RenderBold: true);
                Anchor: (Width: 52);
              }
            }

            // ---- BUILDING category ----
            Label {
              Text: "BUILDING";
              Style: (FontSize: 9, TextColor: #666688, RenderBold: true);
              Anchor: (Height: 16, Bottom: 2);
            }

            // Break row
            Group {
              LayoutMode: Left;
              Anchor: (Height: 28, Bottom: 1);
              Background: (Color: #0d1520);
              Padding: (Left: 6, Right: 6);

              Label {
                Text: "Break";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 114);
              }
              $C.@CheckBoxWithLabel #OutsiderBreakToggle { @Text = ""; @Checked = false; Anchor: (Height: 22, Width: 52); }
              $C.@CheckBoxWithLabel #AllyBreakToggle { @Text = ""; @Checked = false; Anchor: (Height: 22, Width: 52); }
              $C.@CheckBoxWithLabel #MemberBreakToggle { @Text = ""; @Checked = true; Anchor: (Height: 22, Width: 52); }
              $C.@CheckBoxWithLabel #OfficerBreakToggle { @Text = ""; @Checked = true; Anchor: (Height: 22, Width: 52); }
            }

            // Place row
            Group {
              LayoutMode: Left;
              Anchor: (Height: 28, Bottom: 6);
              Background: (Color: #111a28);
              Padding: (Left: 6, Right: 6);

              Label {
                Text: "Place";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 114);
              }
              $C.@CheckBoxWithLabel #OutsiderPlaceToggle { @Text = ""; @Checked = false; Anchor: (Height: 22, Width: 52); }
              $C.@CheckBoxWithLabel #AllyPlaceToggle { @Text = ""; @Checked = false; Anchor: (Height: 22, Width: 52); }
              $C.@CheckBoxWithLabel #MemberPlaceToggle { @Text = ""; @Checked = true; Anchor: (Height: 22, Width: 52); }
              $C.@CheckBoxWithLabel #OfficerPlaceToggle { @Text = ""; @Checked = true; Anchor: (Height: 22, Width: 52); }
            }

            // ---- INTERACTION category ----
            Label {
              Text: "INTERACTION";
              Style: (FontSize: 9, TextColor: #666688, RenderBold: true);
              Anchor: (Height: 16, Bottom: 2);
            }
            Label {
              Text: "(children disabled when All is off)";
              Style: (FontSize: 8, TextColor: #555566);
              Anchor: (Height: 12, Bottom: 2);
            }

            // All (parent) row
            Group {
              LayoutMode: Left;
              Anchor: (Height: 28, Bottom: 1);
              Background: (Color: #0d1520);
              Padding: (Left: 6, Right: 6);

              Label {
                Text: "All";
                Style: (FontSize: 11, TextColor: #CCCCCC, RenderBold: true, VerticalAlignment: Center);
                Anchor: (Width: 114);
              }
              $C.@CheckBoxWithLabel #OutsiderInteractToggle { @Text = ""; @Checked = false; Anchor: (Height: 22, Width: 52); }
              $C.@CheckBoxWithLabel #AllyInteractToggle { @Text = ""; @Checked = false; Anchor: (Height: 22, Width: 52); }
              $C.@CheckBoxWithLabel #MemberInteractToggle { @Text = ""; @Checked = true; Anchor: (Height: 22, Width: 52); }
              $C.@CheckBoxWithLabel #OfficerInteractToggle { @Text = ""; @Checked = true; Anchor: (Height: 22, Width: 52); }
            }

            // Door (child) row
            Group {
              LayoutMode: Left;
              Anchor: (Height: 26, Bottom: 1);
              Background: (Color: #0a1018);
              Padding: (Left: 18, Right: 6);

              Label {
                Text: "Door";
                Style: (FontSize: 10, TextColor: #AAAAAA, VerticalAlignment: Center);
                Anchor: (Width: 102);
              }
              $C.@CheckBoxWithLabel #OutsiderDoorToggle { @Text = ""; @Checked = false; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #AllyDoorToggle { @Text = ""; @Checked = false; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #MemberDoorToggle { @Text = ""; @Checked = true; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #OfficerDoorToggle { @Text = ""; @Checked = true; Anchor: (Height: 20, Width: 52); }
            }

            // Chest (child) row
            Group {
              LayoutMode: Left;
              Anchor: (Height: 26, Bottom: 1);
              Background: (Color: #0a1018);
              Padding: (Left: 18, Right: 6);

              Label {
                Text: "Chest";
                Style: (FontSize: 10, TextColor: #AAAAAA, VerticalAlignment: Center);
                Anchor: (Width: 102);
              }
              $C.@CheckBoxWithLabel #OutsiderContainerToggle { @Text = ""; @Checked = false; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #AllyContainerToggle { @Text = ""; @Checked = false; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #MemberContainerToggle { @Text = ""; @Checked = true; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #OfficerContainerToggle { @Text = ""; @Checked = true; Anchor: (Height: 20, Width: 52); }
            }

            // Bench (child) row
            Group {
              LayoutMode: Left;
              Anchor: (Height: 26, Bottom: 1);
              Background: (Color: #0a1018);
              Padding: (Left: 18, Right: 6);

              Label {
                Text: "Bench";
                Style: (FontSize: 10, TextColor: #AAAAAA, VerticalAlignment: Center);
                Anchor: (Width: 102);
              }
              $C.@CheckBoxWithLabel #OutsiderBenchToggle { @Text = ""; @Checked = false; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #AllyBenchToggle { @Text = ""; @Checked = false; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #MemberBenchToggle { @Text = ""; @Checked = true; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #OfficerBenchToggle { @Text = ""; @Checked = true; Anchor: (Height: 20, Width: 52); }
            }

            // Processing (child) row
            Group {
              LayoutMode: Left;
              Anchor: (Height: 26, Bottom: 1);
              Background: (Color: #0a1018);
              Padding: (Left: 18, Right: 6);

              Label {
                Text: "Processing";
                Style: (FontSize: 10, TextColor: #AAAAAA, VerticalAlignment: Center);
                Anchor: (Width: 102);
              }
              $C.@CheckBoxWithLabel #OutsiderProcessingToggle { @Text = ""; @Checked = false; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #AllyProcessingToggle { @Text = ""; @Checked = false; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #MemberProcessingToggle { @Text = ""; @Checked = true; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #OfficerProcessingToggle { @Text = ""; @Checked = true; Anchor: (Height: 20, Width: 52); }
            }

            // Seat (child) row
            Group {
              LayoutMode: Left;
              Anchor: (Height: 26, Bottom: 1);
              Background: (Color: #0a1018);
              Padding: (Left: 18, Right: 6);

              Label {
                Text: "Seat";
                Style: (FontSize: 10, TextColor: #AAAAAA, VerticalAlignment: Center);
                Anchor: (Width: 102);
              }
              $C.@CheckBoxWithLabel #OutsiderSeatToggle { @Text = ""; @Checked = false; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #AllySeatToggle { @Text = ""; @Checked = false; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #MemberSeatToggle { @Text = ""; @Checked = true; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #OfficerSeatToggle { @Text = ""; @Checked = true; Anchor: (Height: 20, Width: 52); }
            }

            // Transport (child) row
            Group {
              LayoutMode: Left;
              Anchor: (Height: 26);
              Background: (Color: #0a1018);
              Padding: (Left: 18, Right: 6);

              Label {
                Text: "Transport";
                Style: (FontSize: 10, TextColor: #AAAAAA, VerticalAlignment: Center);
                Anchor: (Width: 102);
              }
              $C.@CheckBoxWithLabel #OutsiderTransportToggle { @Text = ""; @Checked = false; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #AllyTransportToggle { @Text = ""; @Checked = false; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #MemberTransportToggle { @Text = ""; @Checked = true; Anchor: (Height: 20, Width: 52); }
              $C.@CheckBoxWithLabel #OfficerTransportToggle { @Text = ""; @Checked = true; Anchor: (Height: 20, Width: 52); }
            }
          }
        }

        // Vertical divider 2
        Group {
          Anchor: (Width: 1);
          Background: (Color: #334455);
        }

        // === RIGHT COLUMN ===
        Group #RightColumn {
          FlexWeight: 1;
          LayoutMode: Top;
          Padding: (Left: 8, Right: 0, Top: 0, Bottom: 0);

          // --- FACTION COLOR ---
          Label {
            Text: "Faction Color";
            Style: (FontSize: 11, TextColor: #888888, RenderBold: true);
            Anchor: (Height: 18, Bottom: 4);
          }
          Group {
            Anchor: (Height: 1, Bottom: 8);
            Background: (Color: #334455);
          }

          Group {
            Background: (Color: #1a2a3a);
            Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
            Anchor: (Height: 200, Bottom: 8);

            ColorPicker #FactionColorPicker {
              DisplayTextField: true;
              Style: $C.@DefaultColorPickerStyle;
            }
          }

          // --- MOB SPAWNING ---
          Label {
            Text: "Mob Spawning";
            Style: (FontSize: 11, TextColor: #888888, RenderBold: true);
            Anchor: (Height: 18, Bottom: 2);
          }
          Label {
            Text: "(children disabled when master is off)";
            Style: (FontSize: 8, TextColor: #666666);
            Anchor: (Height: 12, Bottom: 4);
          }
          Group {
            Anchor: (Height: 1, Bottom: 8);
            Background: (Color: #334455);
          }

          Group #MobSpawningBox {
            Background: (Color: #1a2a3a);
            Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
            LayoutMode: Top;
            Anchor: (Bottom: 8);

            // Master toggle
            Group {
              LayoutMode: Left;
              Anchor: (Height: 28, Bottom: 1);
              Background: (Color: #0d1520);
              Padding: (Left: 6, Right: 6);

              Label {
                Text: "Mob Spawning";
                Style: (FontSize: 11, TextColor: #CCCCCC, VerticalAlignment: Center);
                Anchor: (Width: 120);
              }
              Label { FlexWeight: 1; }
              $C.@CheckBoxWithLabel #MobSpawningToggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 22, Width: 44);
              }
            }

            // Hostile (child)
            Group {
              LayoutMode: Left;
              Anchor: (Height: 26, Bottom: 1);
              Background: (Color: #0a1018);
              Padding: (Left: 18, Right: 6);

              Label {
                Text: "Hostile Mobs";
                Style: (FontSize: 10, TextColor: #FF5555, VerticalAlignment: Center);
                Anchor: (Width: 108);
              }
              Label { FlexWeight: 1; }
              $C.@CheckBoxWithLabel #HostileMobToggle {
                @Text = ""; @Checked = false;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Passive (child)
            Group {
              LayoutMode: Left;
              Anchor: (Height: 26, Bottom: 1);
              Background: (Color: #0a1018);
              Padding: (Left: 18, Right: 6);

              Label {
                Text: "Passive Mobs";
                Style: (FontSize: 10, TextColor: #55FF55, VerticalAlignment: Center);
                Anchor: (Width: 108);
              }
              Label { FlexWeight: 1; }
              $C.@CheckBoxWithLabel #PassiveMobToggle {
                @Text = ""; @Checked = true;
                Anchor: (Height: 20, Width: 44);
              }
            }

            // Neutral (child)
            Group {
              LayoutMode: Left;
              Anchor: (Height: 26);
              Background: (Color: #0a1018);
              Padding: (Left: 18, Right: 6);

              Label {
                Text: "Neutral Mobs";
                Style: (FontSize: 10, TextColor: #FFFF55, VerticalAlignment: Center);
                Anchor: (Width: 108);
              }
              Label { FlexWeight: 1; }
              $C.@CheckBoxWithLabel #NeutralMobToggle {
                @Text = ""; @Checked = true;
                Anchor: (Height: 20, Width: 44);
              }
            }
          }

          // --- COMBAT ---
          Label {
            Text: "Combat";
            Style: (FontSize: 11, TextColor: #888888, RenderBold: true);
            Anchor: (Height: 18, Bottom: 4);
          }
          Group {
            Anchor: (Height: 1, Bottom: 8);
            Background: (Color: #334455);
          }

          Group {
            Background: (Color: #1a2a3a);
            Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
            LayoutMode: Top;
            Anchor: (Bottom: 8);

            Group {
              LayoutMode: Left;
              Anchor: (Height: 30);
              Background: (Color: #0d1520);
              Padding: (Left: 6, Right: 6);

              Label {
                Text: "PvP in Territory";
                Style: (FontSize: 11, TextColor: #AAAAAA, VerticalAlignment: Center);
                Anchor: (Width: 120);
              }
              $C.@CheckBoxWithLabel #PvPToggle {
                @Text = ""; @Checked = true;
                Anchor: (Height: 24, Width: 40);
              }
              Label #PvPStatus {
                Text: "Enabled";
                Style: (FontSize: 10, TextColor: #55FF55, VerticalAlignment: Center);
                FlexWeight: 1;
                Anchor: (Left: 4);
              }
            }
          }

          // Spacer
          Label { FlexWeight: 1; }

          // CREATE button
          Group {
            Anchor: (Height: 45);
            LayoutMode: Left;

            Label { FlexWeight: 1; }

            TextButton #CreateBtn {
              Text: "Create Faction";
              Anchor: (Height: 38, Width: 200);
              Style: $C.@DefaultTextButtonStyle;
            }

            Label { FlexWeight: 1; }
          }
        }
      }
    }
  }
}

// Native Hytale back button
$C.@BackButton {}
